@using Core_Layer.Dtos
@using Core_Layer.Dtos.CategoryDtos
@model List<CategoryListDto>

@{
    ViewData["Title"] = "Category List";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-xl-12 mx-auto">
        <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
            <div class="breadcrumb-title pe-3">Product Management</div>
            <div class="ps-3">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0 p-0">
                        <li class="breadcrumb-item"><a href="/Admin/Dashboard"><i class="bx bx-home-alt"></i></a></li>
                        <li class="breadcrumb-item active" aria-current="page">Category List</li>
                    </ol>
                </nav>
            </div>
            <div class="ms-auto">
                <button type="button" class="btn btn-primary px-4" onclick="openCategoryModal()">
                    <i class='bx bx-plus-circle'></i> Add New Category
                </button>
            </div>
        </div>

        <h6 class="mb-0 text-uppercase">Existing Categories</h6>
        <hr />

        <div class="card border-top border-0 border-4 border-primary">
            <div class="card-body">
                <div class="table-responsive">
                    @if (Model != null && Model.Any())
                    {
                        <table id="example" class="table table-striped table-bordered" style="width:100%">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Name</th>
                                    <th>Description</th>
                                    <th>Has Gender</th>
                                    <th>Created Date</th>
                                    <th>Updated Date</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int count = 1;
                                }
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@count</td>
                                        <td>@item.Name</td>
                                        <td>@item.Description</td>
                                        <td>
                                            @if (item.HasGender)
                                            {
                                                <span class="badge bg-success">Yes</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">No</span>
                                            }
                                        </td>
                                        <td>@item.CreatedDate.ToShortDateString()</td>
                                        <td>
                                            @if (item.UpdatedDate.HasValue)
                                            {
                                                <span class="text-dark">@item.UpdatedDate.Value.ToShortDateString()</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted italic small">Not updated yet</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="d-flex order-actions">
                                                <a href="javascript:;" onclick="openCategoryModal('@item.Id')" class="text-primary bg-light-primary border-0"><i class='bx bxs-edit'></i></a>
                                                <a href="javascript:;" class="ms-3 text-danger bg-light-danger border-0"><i class='bx bxs-trash'></i></a>
                                            </div>
                                        </td>
                                    </tr>
                                    count++;
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="alert alert-info border-0 bg-info alert-dismissible fade show py-2">
                            <div class="d-flex align-items-center">
                                <div class="font-35 text-white"><i class='bx bx-info-circle'></i></div>
                                <div class="ms-3">
                                    <h6 class="mb-0 text-white">Information</h6>
                                    <div class="text-white">No categories found. Click "Add New Category" to start.</div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="categoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-top border-0 border-4 border-primary">
            <div class="modal-header">
                <h5 class="modal-title text-primary" id="modalHeader"><i class="bx bxs-category me-1 font-22"></i>Category Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="categoryForm">
                @* Hidden field for Update operation *@
                <input type="hidden" name="Id" id="categoryId" />

                <div class="modal-body p-4">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-bold">Category Name</label>
                            <div class="input-group">
                                <span class="input-group-text bg-transparent"><i class='bx bxs-tag'></i></span>
                                <input name="Name" id="categoryName" type="text" class="form-control border-start-0" placeholder="e.g. Electronics" required>
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold">Description</label>
                            <textarea name="Description" id="categoryDescription" class="form-control" rows="4" placeholder="Brief description..." required></textarea>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input name="HasGender" class="form-check-input" type="checkbox" id="hasGenderSwitch" value="true">
                                <label class="form-check-label" for="hasGenderSwitch">Includes gender specification?</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                    <button type="submit" id="saveButton" class="btn btn-primary px-4 shadow-sm">Save Category</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/adminassets/plugins/datatable/js/jquery.dataTables.min.js"></script>
    <script src="~/adminassets/plugins/datatable/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        var saveMode = "Add"; // Default mode

        $(document).ready(function() {
            $('#example').DataTable();

            $("#categoryForm").on("submit", function (e) {
                e.preventDefault();
                var formData = $(this).serialize();

                // Dynamic URL selection based on mode
                var targetUrl = saveMode === "Add" ? '/Admin/Category/AddCategory' : '/Admin/Category/UpdateCategory';

                $.ajax({
                    url: targetUrl,
                    type: 'POST',
                    data: formData,
                    success: function (response) {
                        if (response.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Success!',
                                text: response.message,
                                timer: 1500,
                                showConfirmButton: false
                            }).then(() => {
                                location.reload();
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error',
                                html: response.message
                            });
                        }
                    },
                    error: function() {
                        Swal.fire('Error', 'Server communication failure.', 'error');
                    }
                });
            });
        });

        // Dynamic Modal Management
        function openCategoryModal(id = null) {
            $("#categoryForm")[0].reset(); // Formu temizle
            $("#categoryId").val("");

            if (id) {
                // UPDATE MODE
                saveMode = "Update";
                $("#modalHeader").html("<i class='bx bxs-edit me-1 font-22'></i>Update Category");
                $("#saveButton").text("Update Changes");

                // Get current data from server
                $.ajax({
                    url: '/Admin/Category/GetCategory?id=' + id,
                    type: 'GET',
                    success: function (data) {
                        // Data mapping
                        $("#categoryId").val(data.id);
                        $("#categoryName").val(data.name);
                        $("#categoryDescription").val(data.description);
                        $("#hasGenderSwitch").prop("checked", data.hasGender);

                        $('#categoryModal').modal('show');
                    }
                });
            } else {
                // ADD MODE
                saveMode = "Add";
                $("#modalHeader").html("<i class='bx bxs-category me-1 font-22'></i>Add New Category");
                $("#saveButton").text("Save Category");
                $('#categoryModal').modal('show');
            }
        }
    </script>
}
@using Core_Layer.Dtos
@using Core_Layer.Dtos.CategoryDtos
@model List<CategoryListDto>

@{
    ViewData["Title"] = "Category Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-xl-12 mx-auto">
        <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
            <div class="breadcrumb-title pe-3">Category Management</div>
            <div class="ms-auto">
                <button type="button" class="btn btn-primary px-4" onclick="openCategoryModal()">
                    <i class='bx bx-plus-circle'></i> Add New Category
                </button>
            </div>
        </div>

        <div class="card border-top border-0 border-4 border-primary">
            <div class="card-body">
                <div class="table-responsive">
                    <table id="categoryDataTable" class="table table-striped table-bordered align-middle">
                        <thead>
                            <tr>
                                <th style="width: 5%">#</th>
                                <th>Name</th>
                                <th>Has Gender</th>
                                <th class="text-center">Status</th>
                                <th>Created Date</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int count = 1;
                            }
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@count</td>
                                    <td><strong>@item.Name</strong></td>
                                    <td>
                                        <span class="badge @(item.HasGender ? "bg-light-success text-success" : "bg-light-secondary text-secondary")">
                                            @(item.HasGender ? "Yes" : "No")
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        @if (!item.IsDeleted)
                                        {
                                            <span class="text-success h4" title="Active"><i class='bx bxs-check-shield'></i></span>
                                        }
                                        else
                                        {
                                            <span class="text-danger h4" title="Passive"><i class='bx bxs-error-alt'></i></span>
                                        }
                                    </td>
                                    <td>@item.CreatedDate.ToShortDateString()</td>
                                    <td class="text-center">
                                        <div class="d-flex order-actions justify-content-center">
                                            <a href="javascript:;" onclick="manageSubCategories('@item.Id', '@item.Name')" class="text-success bg-light-success border-0 me-2" title="Sub-Categories">
                                                <i class='bx bx-list-ul'></i>
                                            </a>
                                            <a href="javascript:;" onclick="openCategoryModal('@item.Id')" class="text-primary bg-light-primary border-0" title="Edit">
                                                <i class='bx bxs-edit'></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                                count++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@* --- Ana Kategori Modal --- *@
<div class="modal fade" id="categoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-top border-0 border-4 border-primary">
            <div class="modal-header">
                <h5 class="modal-title text-primary" id="modalHeaderTitle">Category Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="categoryForm">
                <input type="hidden" name="Id" id="categoryId" />
                <div class="modal-body p-4">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-bold">Category Name</label>
                            <input name="Name" id="categoryName" type="text" class="form-control" required>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold">Description</label>
                            <textarea name="Description" id="categoryDescription" class="form-control" rows="3" required></textarea>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check form-switch mt-2">
                                <input name="HasGender" class="form-check-input" type="checkbox" id="hasGenderSwitch" value="true">
                                <label class="form-check-label fw-bold">Has Gender?</label>
                            </div>
                        </div>
                        <div class="col-md-6" id="isDeletedContainer" style="display:none;">
                            <div class="form-check form-switch mt-2">
                                <input name="IsDeleted" class="form-check-input" type="checkbox" id="isDeletedSwitch" value="true">
                                <label class="form-check-label text-danger fw-bold">Is Passive?</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary px-4">Save Category</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* --- Alt Kategori Yönetim Modalı --- *@
<div class="modal fade" id="subCategoryManagerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content border-top border-0 border-4 border-success">
            <div class="modal-header">
                <h5 class="modal-title text-success"><i class="bx bx-list-ul me-1"></i> SubCategories of <span id="parentNameDisplay" class="fw-bold"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <table class="table table-sm table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>SubCategory Name</th>
                            <th class="text-center">Status</th>
                            <th>Created Date</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="subCategoryListBody"></tbody>
                </table>
                <hr />
                <form id="addSubCategoryForm" class="row g-2 align-items-end mt-2">
                    <input type="hidden" name="CategoryId" id="hiddenParentId" />
                    <div class="col-9">
                        <label class="form-label fw-bold small">Add New SubCategory</label>
                        <input name="Name" type="text" class="form-control form-control-sm" placeholder="e.g. Smartphones" required>
                    </div>
                    <div class="col-3">
                        <button type="submit" class="btn btn-success btn-sm w-100 shadow-sm"><i class='bx bx-plus'></i> Add</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@* --- Alt Kategori Güncelleme Modalı --- *@
<div class="modal fade" id="subCategoryUpdateModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-top border-0 border-4 border-warning">
            <div class="modal-header">
                <h5 class="modal-title text-warning"><i class="bx bxs-edit me-1"></i>Edit SubCategory</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="updateSubCategoryForm">
                <input type="hidden" name="Id" id="editSubId" />
                <input type="hidden" name="CategoryId" id="editSubParentId" />
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold">SubCategory Name</label>
                        <input name="Name" id="editSubName" type="text" class="form-control" required>
                    </div>
                    <div class="form-check form-switch">
                        @* ID ve Name alanlarına dikkat *@
                        <input name="IsDeleted" class="form-check-input" type="checkbox" id="editSubIsDeleted" value="true">
                        <label class="form-check-label text-danger fw-bold" for="editSubIsDeleted">Mark as Passive</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning px-4 text-white">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/adminassets/plugins/datatable/js/jquery.dataTables.min.js"></script>
    <script src="~/adminassets/plugins/datatable/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        var mainSaveMode = "Add";

        $(document).ready(function() {
            $('#categoryDataTable').DataTable({ "pageLength": 10 });

            // Ana Kategori İşlemi (Fixli)
            $("#categoryForm").on("submit", function (e) {
                e.preventDefault();
                var url = mainSaveMode === "Add" ? '/Admin/Category/AddCategory' : '/Admin/Category/UpdateCategory';

                var formData = $(this).serializeArray();
                if (mainSaveMode === "Update") {
                    var isPassive = $("#isDeletedSwitch").is(":checked");
                    formData = formData.filter(function(i) { return i.name !== "IsDeleted"; });
                    formData.push({ name: "IsDeleted", value: isPassive });
                }

                $.ajax({
                    url: url, type: 'POST', data: $.param(formData),
                    success: function (res) {
                        if (res.success) {
                            Swal.fire({ icon: 'success', title: 'Success', timer: 1500, showConfirmButton: false }).then(() => location.reload());
                        } else { Swal.fire('Error', res.message, 'error'); }
                    }
                });
            });

            // Alt Kategori Ekleme
            $("#addSubCategoryForm").on("submit", function (e) {
                e.preventDefault();
                var parentId = $("#hiddenParentId").val();
                $.ajax({
                    url: '/Admin/SubCategory/AddSubCategory',
                    type: 'POST',
                    data: $(this).serialize(),
                    success: function (res) {
                        if (res.success) {
                            $("#addSubCategoryForm")[0].reset();
                            loadSubCategories(parentId);
                            Swal.fire({ icon: 'success', title: 'Added!', timer: 800, showConfirmButton: false });
                        } else { Swal.fire('Error', res.message, 'error'); }
                    }
                });
            });

            // Alt Kategori Güncelleme - DURUM GÜNCELLEME FİXİ BURADA
            $("#updateSubCategoryForm").on("submit", function (e) {
                e.preventDefault();
                var parentId = $("#editSubParentId").val();

                // Checkbox değerini zorla gönderiyoruz
                var formData = $(this).serializeArray();
                var isPassive = $("#editSubIsDeleted").is(":checked");

                formData = formData.filter(function(item) { return item.name !== "IsDeleted"; });
                formData.push({ name: "IsDeleted", value: isPassive });

                $.ajax({
                    url: '/Admin/SubCategory/UpdateSubCategory',
                    type: 'POST',
                    data: $.param(formData),
                    success: function (res) {
                        if (res.success) {
                            $('#subCategoryUpdateModal').modal('hide');
                            loadSubCategories(parentId);
                            Swal.fire({ icon: 'success', title: 'Updated!', timer: 800, showConfirmButton: false });
                        } else { Swal.fire('Error', res.message, 'error'); }
                    }
                });
            });
        });

        function manageSubCategories(categoryId, categoryName) {
            $("#parentNameDisplay").text(categoryName);
            $("#hiddenParentId").val(categoryId);
            loadSubCategories(categoryId);
            $('#subCategoryManagerModal').modal('show');
        }

        function loadSubCategories(categoryId) {
            $.get('/Admin/SubCategory/GetSubCategoriesByParent?parentId=' + categoryId, function (data) {
                var html = "";
                if (!data || data.length === 0) {
                    html = "<tr><td colspan='4' class='text-center text-muted py-3'>No subcategories found.</td></tr>";
                } else {
                    data.forEach(sub => {
                        var createdDate = new Date(sub.createdDate || sub.CreatedDate).toLocaleDateString();
                        html += `<tr>
                                    <td>${sub.name || sub.Name}</td>
                                    <td class="text-center">
                                        <span class="text-${sub.isDeleted ? 'danger' : 'success'} h5">
                                            <i class='bx ${sub.isDeleted ? 'bxs-error-alt' : 'bxs-check-shield'}'></i>
                                        </span>
                                    </td>
                                    <td>${createdDate}</td>
                                    <td class="text-end">
                                        <a href="javascript:;" onclick="openEditSubModal('${sub.id || sub.Id}', '${categoryId}')" class="text-warning bg-light-warning border-0 p-1 rounded" title="Edit"><i class='bx bxs-edit'></i></a>
                                    </td>
                                 </tr>`;
                    });
                }
                $("#subCategoryListBody").html(html);
            });
        }

        function openEditSubModal(subId, parentId) {
            $.get('/Admin/SubCategory/GetCategory?id=' + subId, function (data) {
                $("#editSubId").val(data.id);
                $("#editSubParentId").val(parentId);
                $("#editSubName").val(data.name);
                $("#editSubIsDeleted").prop("checked", data.isDeleted);
                $('#subCategoryUpdateModal').modal('show');
            });
        }

        function openCategoryModal(id = null) {
            $("#categoryForm")[0].reset();
            $("#categoryId").val("");
            $("#isDeletedContainer").hide();
            if (id) {
                mainSaveMode = "Update";
                $("#isDeletedContainer").show();
                $.get('/Admin/Category/GetCategory?id=' + id, function (data) {
                    $("#categoryId").val(data.id);
                    $("#categoryName").val(data.name);
                    $("#categoryDescription").val(data.description);
                    $("#hasGenderSwitch").prop("checked", data.hasGender);
                    $("#isDeletedSwitch").prop("checked", data.isDeleted);
                    $('#categoryModal').modal('show');
                });
            } else {
                mainSaveMode = "Add";
                $('#categoryModal').modal('show');
            }
        }
    </script>
}
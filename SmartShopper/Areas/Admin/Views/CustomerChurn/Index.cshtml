@using Core_Layer.Dtos.ChurnPredictionDtos
@model List<ChurnPredictionResultDto>

@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery

@{
    ViewData["Title"] = "AI Churn Risk Center";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int count = 1;

    // Controller'dan gelen kalite metriklerini DTO olarak yakalıyoruz
    var metrics = ViewBag.ModelMetrics as ChurnEvaluationReportDto;
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-4">
    <div class="breadcrumb-title pe-3">SmartShopper AI</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a href="javascript:;"><i class="bx bx-error-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Predictive Churn Analysis</li>
            </ol>
        </nav>
    </div>
</div>

@Html.AntiForgeryToken()

<div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 mb-4">

    <div class="col">
        <div class="card radius-10 border-start border-0 border-3 border-danger shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <p class="mb-0 text-secondary">Risk Analysis Engine</p>
                        <h5 class="my-1 text-danger">Logistic Regression</h5>
                        <p class="mb-0 font-13 text-success"><i class='bx bxs-check-shield'></i> Trained Model Ready</p>
                    </div>
                    <div class="widgets-icons-2 rounded-circle bg-light-danger text-danger ms-auto">
                        <i class='bx bx-pulse'></i>
                    </div>
                </div>
                <div class="mt-3">
                    <button onclick="executeChurnAnalysis()" class="btn btn-danger btn-sm px-4 radius-30 shadow-sm w-100">
                        <i class='bx bx-refresh'></i> Run AI Risk Scan
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card radius-10 border-start border-0 border-3 border-success shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-2">
                    <div>
                        <p class="mb-0 text-secondary">AI Accuracy Score</p>
                        @if (metrics != null && metrics.Accuracy > 0)
                        {
                            <h4 class="my-1 text-success">%@metrics.Accuracy</h4>
                        }
                        else
                        {
                            <h4 class="my-1 text-danger">Not Trained</h4>
                        }
                    </div>
                    <div class="widgets-icons-2 rounded-circle bg-light-success text-success ms-auto">
                        <i class='bx bx-check-double'></i>
                    </div>
                </div>
                @if (metrics != null && metrics.Accuracy > 0)
                {
                    <p class="mb-0 font-13 text-secondary">
                        <strong>F1:</strong> %@metrics.F1Score | <strong>Recall:</strong> %@metrics.Recall
                    </p>
                    <p class="mb-0 font-13 text-muted mt-1" style="font-size: 11px !important;">
                        <i class='bx bx-time'></i> @metrics.EvaluatedAt.ToString("dd MMM yyyy")
                    </p>
                }
                else
                {
                    <p class="mb-0 font-13 text-danger">Please run the AI scan to calculate metrics.</p>
                }
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card radius-10 border-start border-0 border-3 border-warning shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <p class="mb-0 text-secondary">High Risk Customers</p>
                        <h4 class="my-1 text-warning" id="highRiskCount">
                            @(Model?.Count(x => x.ChurnProbability > 50) ?? 0) Users
                        </h4>
                        <p class="mb-0 font-13">Requiring Immediate Action</p>
                    </div>
                    <div class="widgets-icons-2 rounded-circle bg-light-warning text-warning ms-auto">
                        <i class='bx bx-alarm-exclamation'></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card radius-10 border-start border-0 border-3 border-primary shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <p class="mb-0 text-secondary">Total Analyzed</p>
                        <h4 class="my-1 text-primary">@(Model?.Count ?? 0) Users</h4>
                        <p class="mb-0 font-13">Last Scan: @(Model?.FirstOrDefault()?.LastUpdated.ToString("dd MMM HH:mm") ?? "N/A")</p>
                    </div>
                    <div class="widgets-icons-2 rounded-circle bg-light-primary text-primary ms-auto">
                        <i class='bx bx-user-pin'></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card radius-10 shadow-none border">
    <div class="card-header bg-transparent border-bottom">
        <h6 class="mb-0 fw-bold">Retention Risk Management Table</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table id="churnDataTable" class="table align-middle mb-0 table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Customer</th>
                        <th>Risk Probability</th>
                        <th>Financial Value</th>
                        <th>Order Count</th>
                        <th>Status</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>
                <tbody id="churnTableBody">
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm bg-light-primary text-primary rounded-circle p-2 me-2 text-center" style="width:35px; height:35px">
                                            <i class='bx bxs-user-circle fs-5'></i>
                                        </div>
                                        <div>
                                            <h6 class="mb-0 font-14">@item.UserFullName</h6>
                                            <small class="text-muted">Last Active: @item.Recency.ToString("0") days ago</small>
                                        </div>
                                    </div>
                                </td>
                                <td style="width: 220px;">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress flex-grow-1" style="height: 6px;">
                                            <div class="progress-bar @(item.ChurnProbability > 70 ? "bg-danger" : item.ChurnProbability > 40 ? "bg-warning" : "bg-success")"
                                                 role="progressbar" style="width: @(item.ChurnProbability.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                                        </div>
                                        <span class="font-13 fw-bold">%@item.ChurnProbability.ToString("0.0")</span>
                                    </div>
                                </td>
                                <td><h6 class="mb-0 font-14 text-success">$ @item.Monetary.ToString("N2")</h6></td>
                                <td>@item.Frequency Orders</td>
                                <td>
                                    @if (item.ChurnProbability > 50)
                                    {
                                        <span class="badge bg-light-danger text-danger border border-danger px-3 radius-30">CHURN RISK</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light-success text-success border border-success px-3 radius-30">STABLE</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-primary px-3 radius-30"
                                            onclick="openAssignDiscountModal('@item.AppUserId', '@item.UserFullName')">
                                        <i class="bx bx-gift me-1"></i> Offer Discount
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="assignDiscountModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-top border-0 border-4 border-primary">
            <div class="modal-header">
                <h5 class="modal-title text-primary"><i class='bx bx-gift me-1'></i> Retention Offer: <span id="assignUserName" class="fw-bold"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="assignDiscountForm">
                <input type="hidden" name="AppUserId" id="assignAppUserId" />
                <div class="modal-body p-4">
                    <p class="text-muted small mb-3">Select an active campaign to define for this user. The discount will be added to their account immediately.</p>
                    <div class="mb-3">
                        <label class="form-label">Available Campaigns</label>
                        <select name="DiscountId" id="discountSelect" class="form-select" required>
                            <option value="">-- Loading Campaigns... --</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" id="btnAssignSave" class="btn btn-primary px-4">Assign Discount</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/adminassets/plugins/datatable/js/jquery.dataTables.min.js"></script>
    <script src="~/adminassets/plugins/datatable/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            $('#churnDataTable').DataTable({
                order: [[1, "desc"]],
                pageLength: 10
            });
        });

        function openAssignDiscountModal(userId, fullName) {
            $("#assignAppUserId").val(userId);
            $("#assignUserName").text(fullName);

            $("#discountSelect").html('<option value="">Loading...</option>');
            $("#assignDiscountModal").modal('show');

            $.get('/Admin/Discount/GetActiveDiscounts', function (data) {
                let html = '<option value="">-- Select a Campaign --</option>';
                if(data && data.length > 0) {
                    data.forEach(item => {
                        let typeInfo = item.type === 1 ? '%' + item.value : item.value + ' TL';
                        html += `<option value="${item.id}">${item.name} (${typeInfo})</option>`;
                    });
                } else {
                    html = '<option value="">No active campaigns found</option>';
                }
                $("#discountSelect").html(html);
            }).fail(function() {
                $("#discountSelect").html('<option value="">Error loading campaigns</option>');
            });
        }

        $("#assignDiscountForm").on("submit", function (e) {
            e.preventDefault();
            const $btn = $("#btnAssignSave");
            $btn.prop("disabled", true).html('<span class="spinner-border spinner-border-sm"></span> Processing...');

            $.ajax({
                url: '/Admin/Discount/AssignDiscount',
                type: 'POST',
                data: $(this).serialize(),
                success: function (res) {
                    if (res.success) {
                        $("#assignDiscountModal").modal('hide');
                        Swal.fire({
                            icon: 'success',
                            title: 'Success!',
                            text: res.message,
                            timer: 2000,
                            showConfirmButton: false
                        });
                    } else {
                        Swal.fire('Warning', res.message, 'warning');
                    }
                },
                error: function () {
                    Swal.fire('Error', 'An unexpected error occurred during assignment.', 'error');
                },
                complete: function() {
                    $btn.prop("disabled", false).text("Assign Discount");
                }
            });
        });

        function executeChurnAnalysis() {
            Swal.fire({
                title: 'AI Intelligence Scanning',
                text: 'Analyzing customer behavior patterns...',
                allowOutsideClick: false,
                didOpen: () => { Swal.showLoading(); }
            });

            var token = $('input[name="__RequestVerificationToken"]').val();

            $.ajax({
                url: '@Url.Action("RunAnalysis", "CustomerChurn", new { area = "Admin" })',
                type: 'POST',
                data: { __RequestVerificationToken: token },
                success: function (res) {
                    if (res.success) {
                        Swal.fire({ icon: 'success', title: 'Completed', text: res.message, timer: 2000, showConfirmButton: false })
                        .then(() => location.reload());
                    } else {
                        Swal.fire('Error', res.message, 'error');
                    }
                },
                error: function (xhr) {
                    Swal.fire('Server Error', 'Request failed: ' + xhr.statusText, 'error');
                }
            });
        }
    </script>
}
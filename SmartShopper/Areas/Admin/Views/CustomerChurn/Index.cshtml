@using Core_Layer.Dtos.ChurnPredictionDtos
@model List<ChurnPredictionResultDto>

@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery

@{
    ViewData["Title"] = "AI Churn Risk Center";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int count = 1;
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-4">
    <div class="breadcrumb-title pe-3">SmartShopper AI</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a href="javascript:;">
                        <i class="bx bx-error-alt"></i>
                    </a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">
                    Predictive Churn Analysis
                </li>
            </ol>
        </nav>
    </div>
</div>

@Html.AntiForgeryToken()

<div class="row row-cols-1 row-cols-md-3 row-cols-xl-3 mb-4">

    <div class="col">
        <div class="card radius-10 border-start border-0 border-3 border-danger shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <p class="mb-0 text-secondary">Risk Analysis Engine</p>
                        <h4 class="my-1 text-danger">Logistic Regression</h4>
                        <p class="mb-0 font-13 text-success">
                            <i class='bx bxs-check-shield'></i>
                            Trained Model Ready
                        </p>
                    </div>

                    <div class="widgets-icons-2 rounded-circle bg-light-danger text-danger ms-auto">
                        <i class='bx bx-pulse'></i>
                    </div>
                </div>

                <div class="mt-3">
                    <button onclick="executeChurnAnalysis()"
                            class="btn btn-danger btn-sm px-4 radius-30 shadow-sm">
                        <i class='bx bx-refresh'></i>
                        Run AI Risk Scan
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card radius-10 border-start border-0 border-3 border-warning">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <p class="mb-0 text-secondary">High Risk Customers</p>
                        <h4 class="my-1 text-warning" id="highRiskCount">
                            @(Model?.Count(x => x.ChurnProbability > 50) ?? 0) Users
                        </h4>
                        <p class="mb-0 font-13">
                            Requiring Immediate Action
                        </p>
                    </div>

                    <div class="widgets-icons-2 rounded-circle bg-light-warning text-warning ms-auto">
                        <i class='bx bx-alarm-exclamation'></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card radius-10 border-start border-0 border-3 border-primary">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <p class="mb-0 text-secondary">Total Customers Analyzed</p>
                        <h4 class="my-1 text-primary">
                            @(Model?.Count ?? 0) Users
                        </h4>
                        <p class="mb-0 font-13">
                            Last System Scan: @(Model?.FirstOrDefault()?.LastUpdated.ToString("dd MMM HH:mm") ?? "N/A")
                        </p>
                    </div>

                    <div class="widgets-icons-2 rounded-circle bg-light-primary text-primary ms-auto">
                        <i class='bx bx-user-pin'></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

<div class="card radius-10 shadow-none border">
    <div class="card-header bg-transparent border-bottom">
        <div class="d-flex align-items-center">
            <div>
                <h6 class="mb-0 fw-bold">
                    Retention Risk Management Table
                </h6>
            </div>
        </div>
    </div>

    <div class="card-body">
        <div class="table-responsive">

            <table id="churnDataTable" class="table align-middle mb-0 table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Customer</th>
                        <th>Risk Probability</th>
                        <th>Financial Value</th>
                        <th>Order Count</th>
                        <th>Status</th>
                    </tr>
                </thead>

                <tbody id="churnTableBody">

                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm bg-light-primary text-primary rounded-circle p-2 me-2 text-center"
                                             style="width:35px; height:35px">
                                            <i class='bx bxs-user-circle fs-5'></i>
                                        </div>
                                        <div>
                                            <h6 class="mb-0 font-14">
                                                @item.UserFullName
                                            </h6>
                                            <small class="text-muted">
                                                Last Active: @item.Recency.ToString("0") days ago
                                            </small>
                                        </div>
                                    </div>
                                </td>

                                <td style="width: 220px;">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress flex-grow-1" style="height: 6px;">
                                            <div class="progress-bar @(item.ChurnProbability > 70 ? "bg-danger" : item.ChurnProbability > 40 ? "bg-warning" : "bg-success")"
                                                 role="progressbar"
                                                 style="width: @(item.ChurnProbability.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))%">
                                            </div>
                                        </div>
                                        <span class="font-13 fw-bold">
                                            %@item.ChurnProbability.ToString("0.0")
                                        </span>
                                    </div>
                                </td>

                                <td>
                                    <h6 class="mb-0 font-14 text-success">
                                        $ @item.Monetary.ToString("N2")
                                    </h6>
                                </td>

                                <td>
                                    @item.Frequency Orders
                                </td>

                                <td>
                                    @if (item.ChurnProbability > 50)
                                    {
                                        <span class="badge bg-light-danger text-danger border border-danger px-3 radius-30">
                                            CHURN RISK
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light-success text-success border border-success px-3 radius-30">
                                            STABLE
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <h6>No analysis data found.</h6>
                                <p class="text-muted">
                                    Click "Run AI Risk Scan" to generate customer churn predictions.
                                </p>
                            </td>
                        </tr>
                    }

                </tbody>
            </table>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/adminassets/plugins/datatable/js/jquery.dataTables.min.js"></script>
    <script src="~/adminassets/plugins/datatable/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            // DataTable'ı risk skoruna (Kolon 1) göre azalan şekilde başlattık
            $('#churnDataTable').DataTable({
                order: [[1, "desc"]],
                pageLength: 10
            });
        });

        function executeChurnAnalysis() {
            Swal.fire({
                title: 'AI Intelligence Scanning',
                text: 'Analyzing customer behavior patterns and calculating churn probabilities...',
                allowOutsideClick: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            // AntiForgery Token alıyoruz (XSS ve CSRF ataklarına karşı koruma)
            var token = $('input[name="__RequestVerificationToken"]').val();

            $.ajax({
                // SENIOR FIX: Url Action helper ile statik URL yerine dinamik güvenli URL üretimi
                url: '@Url.Action("RunAnalysis", "CustomerChurn", new { area = "Admin" })',
                type: 'POST',
                data: {
                    __RequestVerificationToken: token
                },
                success: function (res) {
                    if (res.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Analysis Completed',
                            text: 'Risk scores have been updated successfully.',
                            timer: 2000,
                            showConfirmButton: false
                        }).then(() => {
                            location.reload();
                        });
                    } else {
                        Swal.fire(
                            'Error',
                            res.message,
                            'error'
                        );
                    }
                },
                error: function (xhr) {
                    Swal.fire(
                        'Server Error',
                        'Request failed. Server responded with: ' + xhr.statusText,
                        'error'
                    );
                }
            });
        }
    </script>
}
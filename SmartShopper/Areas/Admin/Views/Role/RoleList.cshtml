@using Core_Layer.Dtos.RoleDtos
@model List<RoleListDto>

@{
    ViewData["Title"] = "Role Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int count = 1;
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">User & Role</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item"><a href="javascript:;"><i class="bx bx-home-alt"></i></a></li>
                <li class="breadcrumb-item active" aria-current="page">Role Management</li>
            </ol>
        </nav>
    </div>
    <div class="ms-auto">
        <button type="button" class="btn btn-primary px-4" onclick="openRoleModal()">
            <i class='bx bx-plus-circle'></i> Add New Role
        </button>
    </div>
</div>

<h6 class="mb-0 text-uppercase">System Roles</h6>
<hr />

<div class="card border-top border-0 border-4 border-primary">
    <div class="card-body">
        <div class="table-responsive">
            <table id="roleDataTable" class="table table-striped table-bordered" style="width:100%">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Role Name</th>
                        <th>Description</th>
                        <th>Created Date</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@count</td>
                            <td>
                                <div class="badge rounded-pill text-primary bg-light-primary p-2 text-uppercase px-3">
                                    <i class='bx bxs-circle me-1'></i>@item.RoleName
                                </div>
                            </td>
                            <td>@item.Description</td>
                            <td>@item.CreatedDate.ToShortDateString()</td>
                            <td class="text-center">
                                <div class="d-flex order-actions justify-content-center">
                                    <a href="javascript:;" class="text-primary bg-light-primary border-0 me-2" onclick="editRole('@item.Id')">
                                        <i class='bx bxs-edit'></i>
                                    </a>

                                    <a href="javascript:;" class="text-danger bg-light-danger border-0" onclick="deleteRole('@item.Id')">
                                        <i class='bx bxs-trash'></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        count++;
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="roleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-top border-0 border-4 border-primary">
            <div class="modal-header">
                <h5 class="modal-title text-primary" id="modalHeaderTitle">Create New Role</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="roleForm">
                <input type="hidden" name="Id" id="roleId" />

                <div class="modal-body">
                    <div class="col-12 mb-3">
                        <label class="form-label fw-bold">Role Name</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class='bx bx-shield-quarter'></i></span>
                            <input type="text" name="RoleName" id="roleNameInput" class="form-control" placeholder="e.g. Admin, Editor" required>
                        </div>
                    </div>
                    <div class="col-12 mb-3">
                        <label class="form-label fw-bold">Description</label>
                        <textarea name="Description" id="roleDescriptionInput" class="form-control" rows="3" placeholder="What is this role for?"></textarea>
                    </div>
                    <div id="modalErrorArea" class="text-danger small px-2"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" id="btnSaveRole" class="btn btn-primary px-4">Save Role</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/adminassets/plugins/datatable/js/jquery.dataTables.min.js"></script>
    <script src="~/adminassets/plugins/datatable/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        var saveMode = "Add";

        $(document).ready(function () {
            $('#roleDataTable').DataTable();

            $("#roleForm").on("submit", function (e) {
                e.preventDefault();

                const url = saveMode === "Add" ? '/Admin/Role/CreateRole' : '/Admin/Role/UpdateRole';
                const $btn = $("#btnSaveRole");

                $btn.prop("disabled", true).html('<span class="spinner-border spinner-border-sm"></span> Processing...');

                $.ajax({
                    url: url,
                    type: 'POST',
                    data: $(this).serialize(),
                    success: function (res) {
                        if (res.success) {
                            $("#roleModal").modal('hide');
                            Swal.fire({
                                icon: 'success',
                                title: 'Success!',
                                text: res.message,
                                timer: 1500,
                                showConfirmButton: false
                            }).then(() => {
                                location.reload();
                            });
                        } else {
                            $("#modalErrorArea").html('<i class="bx bx-error-circle"></i> ' + res.message);
                            $btn.prop("disabled", false).text("Save Role");
                        }
                    },
                    error: function () {
                        Swal.fire('Error!', 'An unexpected error occurred.', 'error');
                        $btn.prop("disabled", false).text("Save Role");
                    }
                });
            });
        });

        function openRoleModal() {
            saveMode = "Add";
            $("#roleForm")[0].reset();
            $("#roleId").val("");
            $("#modalHeaderTitle").text("Create New Role");
            $("#modalErrorArea").empty();
            $("#roleModal").modal('show');
        }

        function editRole(id) {
            saveMode = "Update";
            $("#modalErrorArea").empty();
            $("#modalHeaderTitle").text("Update Role");

            $.get('/Admin/Role/GetRole?id=' + id, function (data) {
                $("#roleId").val(data.id);
                $("#roleNameInput").val(data.roleName);
                $("#roleDescriptionInput").val(data.description);

                $("#roleModal").modal('show');
            }).fail(function() {
                Swal.fire('Error!', 'Could not fetch role details.', 'error');
            });
        }

        function deleteRole(id) {
            Swal.fire({
                title: 'Are you sure?',
                text: "This role will be permanently deleted!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/Admin/Role/DeleteRole',
                        type: 'POST',
                        data: { id: id },
                        success: function (res) {
                            if (res.success) {
                                Swal.fire('Deleted!', res.message, 'success').then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire('Error!', res.message, 'error');
                            }
                        },
                        error: function () {
                            Swal.fire('Error!', 'An error occurred while deleting.', 'error');
                        }
                    });
                }
            })
        }
    </script>
}
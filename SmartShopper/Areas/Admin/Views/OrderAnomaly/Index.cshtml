@using Core_Layer.Dtos.OrderAnomalyDtos
@model List<OrderAnomalyDto>

@{
    ViewData["Title"] = "AI Fraud & Anomaly Detection";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@Html.AntiForgeryToken()

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-4">
    <div class="breadcrumb-title pe-3">Security AI</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item"><a href="javascript:;"><i class="bx bx-shield-quarter"></i></a></li>
                <li class="breadcrumb-item active" aria-current="page">Fraud Detection Center</li>
            </ol>
        </nav>
    </div>
</div>

<div class="card radius-10 shadow-sm border-0 border-start border-4 border-danger">
    <div class="card-body">
        <div class="d-flex align-items-center">
            <div>
                <h5 class="mb-0 text-danger fw-bold">Anomaly Detection & Risk Analysis</h5>
                <p class="mb-0 text-secondary">SSA (Singular Spectrum Analysis) is scanning transaction patterns.</p>
            </div>
            <div class="ms-auto">
                <button onclick="runAnomalyScan()" class="btn btn-danger radius-30 px-4 shadow-sm">
                    <i class='bx bx-scan'></i> Run Security Scan
                </button>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-12">
        <div class="card radius-10">
            <div class="card-header bg-transparent">
                <div class="d-flex align-items-center">
                    <div><h6 class="mb-0 fw-bold">Flagged Risky Transactions</h6></div>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table id="anomalyTable" class="table align-middle mb-0 table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Order ID</th>
                                <th>Customer</th>
                                <th>Amount</th>
                                <th>Risk Score</th>
                                <th>P-Value</th>
                                <th>Status</th>
                                <th>Reason</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>#@item.OrderId.ToString().Substring(0, 8)</td>
                                    <td>@item.CustomerName</td>
                                    <td class="fw-bold">$ @item.OrderTotal.ToString("N2")</td>
                                    <td>
                                        <div class="progress" style="height: 6px;">
                                            <div class="progress-bar bg-danger" style="width: @item.RiskPercentage%"></div>
                                        </div>
                                        <small class="text-danger">@item.RiskPercentage% Risk</small>
                                    </td>
                                    <td><code>@item.PValue.ToString("F6")</code></td>
                                    <td>
                                        <span class="badge bg-light-danger text-danger border border-danger px-3 radius-30">HIGH RISK</span>
                                    </td>
                                    <td><small class="text-muted">@item.Description</small></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function runAnomalyScan() {
            Swal.fire({
                title: 'AI Security Scanning...',
                text: 'Analyzing historical transaction spikes and p-values.',
                allowOutsideClick: false,
                didOpen: () => { Swal.showLoading(); }
            });

        $.post('@Url.Action("RunDetection", "OrderAnomaly", new { area = "Admin" })', {
            "__RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val()
        }, function(res) {
            if (res.success) {
                Swal.fire('Success', res.message, 'success').then(() => location.reload());
            } else {
                Swal.fire('Notice', res.message, 'info');
            }
        }).fail(function(xhr) {
            Swal.fire('Server Error', 'Status: ' + xhr.status + ' - Sunucu ile iletişim kurulamadı. Hatayı console üzerinden inceleyin.', 'error');
        });
        }
    </script>
}
@using Core_Layer.Dtos.OrderAnomalyDtos
@model List<OrderAnomalyDto>

@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery

@{
    ViewData["Title"] = "AI Fraud & Anomaly Detection";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    // Controller'dan gelen kalite metriklerini DTO olarak yakalıyoruz
    var metrics = ViewBag.ModelMetrics as AnomalyEvaluationReportDto;
}

@Html.AntiForgeryToken()

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-4">
    <div class="breadcrumb-title pe-3">Security AI</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item"><a href="javascript:;"><i class="bx bx-shield-quarter"></i></a></li>
                <li class="breadcrumb-item active" aria-current="page">Fraud Detection Center</li>
            </ol>
        </nav>
    </div>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 mb-4">

    <div class="col">
        <div class="card radius-10 border-start border-0 border-3 border-danger shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div>
                        <p class="mb-0 text-secondary">SSA Security Engine</p>
                        <h5 class="my-1 text-danger">Active Tracker</h5>
                    </div>
                    <div class="widgets-icons-2 rounded-circle bg-light-danger text-danger ms-auto">
                        <i class='bx bx-radar'></i>
                    </div>
                </div>
                <button onclick="runAnomalyScan()" class="btn btn-danger btn-sm w-100 radius-30 shadow-sm">
                    <i class='bx bx-scan'></i> Run Full Security Scan
                </button>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card radius-10 border-start border-0 border-3 border-success shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <p class="mb-0 text-secondary">Statistical Confidence</p>
                        @if (metrics != null && metrics.ConfidenceLevel > 0)
                        {
                            <h4 class="my-1 text-success">%@metrics.ConfidenceLevel</h4>
                            <p class="mb-0 font-13 text-muted">Precision Level</p>
                        }
                        else
                        {
                            <h4 class="my-1 text-muted">N/A</h4>
                        }
                    </div>
                    <div class="widgets-icons-2 rounded-circle bg-light-success text-success ms-auto">
                        <i class='bx bx-check-shield'></i>
                    </div>
                </div>
                @if (metrics != null && metrics.ConfidenceLevel > 0)
                {
                    <div class="mt-3">
                        <p class="mb-0 font-13 text-secondary">
                            <i class='bx bx-time'></i> Last Scan: @metrics.EvaluatedAt.ToString("dd MMM yyyy")
                        </p>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card radius-10 border-start border-0 border-3 border-warning shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <p class="mb-0 text-secondary">Anomaly Detection Rate</p>
                        <h4 class="my-1 text-warning">%@(metrics?.AnomalyDetectionRate.ToString("0.00") ?? "0.00")</h4>
                        <p class="mb-0 font-13 text-muted">Of total transactions</p>
                    </div>
                    <div class="widgets-icons-2 rounded-circle bg-light-warning text-warning ms-auto">
                        <i class='bx bx-pie-chart-alt-2'></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card radius-10 border-start border-0 border-3 border-primary shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <p class="mb-0 text-secondary">Analysis Volume</p>
                        <h4 class="my-1 text-primary">@(metrics?.TotalAnalyzedOrders ?? 0) Orders</h4>
                        <p class="mb-0 font-13 text-muted">
                            <strong class="text-danger">@(metrics?.TotalAnomaliesFound ?? 0)</strong> anomalies found
                        </p>
                    </div>
                    <div class="widgets-icons-2 rounded-circle bg-light-primary text-primary ms-auto">
                        <i class='bx bx-data'></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-12">
        <div class="card radius-10">
            <div class="card-header bg-transparent border-bottom">
                <div class="d-flex align-items-center">
                    <div><h6 class="mb-0 fw-bold">Flagged Risky Transactions</h6></div>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table id="anomalyTable" class="table align-middle mb-0 table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Order ID</th>
                                <th>Customer</th>
                                <th>Amount</th>
                                <th>Risk Score</th>
                                <th>P-Value</th>
                                <th>Status</th>
                                <th>Reason</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td><span class="text-muted">#@item.OrderId.ToString().Substring(0, 8)</span></td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="avatar-sm bg-light-danger text-danger rounded-circle p-2 me-2 text-center" style="width:35px; height:35px">
                                                    <i class='bx bx-user-x fs-5'></i>
                                                </div>
                                                <h6 class="mb-0 font-14">@item.CustomerName</h6>
                                            </div>
                                        </td>
                                        <td class="fw-bold text-dark">$ @item.OrderTotal.ToString("N2")</td>
                                        <td style="width: 150px;">
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="progress flex-grow-1" style="height: 6px;">
                                                    <div class="progress-bar bg-danger" style="width: @item.RiskPercentage.ToString().Replace(",", ".")%"></div>
                                                </div>
                                                <small class="text-danger fw-bold">@item.RiskPercentage%</small>
                                            </div>
                                        </td>
                                        <td><code>@item.PValue.ToString("F6")</code></td>
                                        <td>
                                            <span class="badge bg-light-danger text-danger border border-danger px-3 radius-30">SPIKE ANOMALY</span>
                                        </td>
                                        <td style="max-width: 250px;">
                                            <small class="text-muted text-wrap">@item.Description</small>
                                        </td>
                                        <td>
                                            <button type="button" class="btn btn-outline-primary btn-sm radius-30 px-3"
                                                    onclick="showOrderHistory('@item.OrderId', '@item.CustomerName')">
                                                <i class='bx bx-history'></i> History
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" class="text-center text-muted py-4">
                                        <i class='bx bx-check-shield fs-1 text-success mb-2'></i><br />
                                        No risky transactions detected yet.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="orderHistoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-bottom-0">
                <h5 class="modal-title">Order History: <span id="modalCustomerName" class="text-primary fw-bold"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th class="ps-4">Order Date</th>
                                <th>Total Amount</th>
                            </tr>
                        </thead>
                        <tbody id="historyTableBody">
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer border-top-0">
                <button type="button" class="btn btn-secondary radius-30 px-4" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/adminassets/plugins/datatable/js/jquery.dataTables.min.js"></script>
    <script src="~/adminassets/plugins/datatable/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            $('#anomalyTable').DataTable({
                order: [[3, "desc"]], 
                pageLength: 10
            });
        });

        function runAnomalyScan() {
            Swal.fire({
                title: 'AI Security Scanning...',
                text: 'Analyzing historical transaction spikes and p-values.',
                allowOutsideClick: false,
                didOpen: () => { Swal.showLoading(); }
            });

            var token = $('input[name="__RequestVerificationToken"]').val();
            $.post('@Url.Action("RunDetection", "OrderAnomaly", new { area = "Admin" })', {
                "__RequestVerificationToken": token
            }, function(res) {
                if (res.success) {
                    Swal.fire('Success', res.message, 'success').then(() => location.reload());
                } else {
                    Swal.fire('Notice', res.message, 'info');
                }
            }).fail(function(xhr) {
                Swal.fire('Server Error', 'Status: ' + xhr.status + ' - An error occurred during the scan.', 'error');
            });
        }

        function showOrderHistory(orderId, customerName) {
            $("#modalCustomerName").text(customerName);
            $("#historyTableBody").html('<tr><td colspan="2" class="text-center py-3"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div></td></tr>');
            $("#orderHistoryModal").modal('show');

            $.get('@Url.Action("GetOrderHistory", "OrderAnomaly", new { area = "Admin" })/' + orderId, function (data) {
                let rows = "";
                if (data.length === 0) {
                    rows = '<tr><td colspan="2" class="text-center text-muted py-3">No previous history found for this customer.</td></tr>';
                } else {
                    data.forEach(item => {
                        rows += `<tr>
                            <td class="ps-4">${item.orderDateString}</td>
                            <td class="fw-bold text-success">$ ${item.totalPrice.toLocaleString('en-US', {minimumFractionDigits: 2})}</td>
                        </tr>`;
                    });
                }
                $("#historyTableBody").html(rows);
            }).fail(function() {
                $("#historyTableBody").html('<tr><td colspan="2" class="text-center text-danger py-3">Error loading history data.</td></tr>');
            });
        }
    </script>
}
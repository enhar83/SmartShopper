@using Core_Layer.Dtos.CustomerSegmentationDtos
@model List<CustomerSegmentResultDto>
@{
    ViewData["Title"] = "AI Customer Insights";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int count = 1;
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">SmartShopper AI</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item"><a href="javascript:;"><i class="bx bx-chip"></i></a></li>
                <li class="breadcrumb-item active" aria-current="page">Customer DNA Analysis</li>
            </ol>
        </nav>
    </div>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-xl-2 mb-4">
    <div class="col">
        <div class="card radius-10 border-start border-0 border-3 border-info">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <p class="mb-0 text-secondary">Intelligence Engine Status</p>
                        <h4 class="my-1 text-info">K-Means AI</h4>
                        <p class="mb-0 font-13 text-success"><i class='bx bxs-check-circle'></i> Active & Optimized</p>
                    </div>
                    <div class="widgets-icons-2 rounded-circle bg-light-info text-info ms-auto"><i class='bx bx-brain'></i></div>
                </div>
                <div class="mt-3">
                    <button onclick="executeMLTask('/Admin/CustomerSegmentation/TrainModel', 'Training...')" class="btn btn-outline-info btn-sm px-3 radius-30">Retrain Model</button>
                    <button onclick="executeMLTask('/Admin/CustomerSegmentation/ProcessBatch', 'Analyzing...')" class="btn btn-info btn-sm px-3 radius-30 text-white">Update All Segments</button>
                </div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card radius-10 border-start border-0 border-3 border-warning">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <p class="mb-0 text-secondary">Analyzed Audience</p>
                        <h4 class="my-1 text-warning">@(Model?.Count ?? 0) Users</h4>
                        <p class="mb-0 font-13">Last Refresh: @(Model?.FirstOrDefault()?.LastUpdated.ToString("g") ?? "No Data")</p>
                    </div>
                    <div class="widgets-icons-2 rounded-circle bg-light-warning text-warning ms-auto"><i class='bx bx-group'></i></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card radius-10">
    <div class="card-body">
        <div class="table-responsive">
            <table id="segmentationDataTable" class="table table-striped table-bordered align-middle">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Customer Profile</th>
                        <th>AI Segment</th>
                        <th>Analysis Date</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model ?? new List<CustomerSegmentResultDto>())
                    {
                        <tr>
                            <td>@count</td>
                            <td>
                                <h6 class="mb-0 font-14">@item.UserFullName</h6>
                                <small class="text-muted">ID: @item.AppUserId.ToString().Substring(0, 8)</small>
                            </td>
                            <td>
                                <div class="badge rounded-pill p-2 px-3 text-uppercase shadow-none"
                                     style="background-color: @(item.StatusColor)22; color: @item.StatusColor; border: 1px solid @item.StatusColor">
                                    @item.SegmentLabel
                                </div>
                            </td>
                            <td>@item.LastUpdated.ToString("MM.dd.yyyy")</td>
                            <td>
                                <button class="btn btn-sm btn-light-primary radius-30 px-3" onclick="refreshIndividual('@item.AppUserId')">
                                    <i class='bx bx-show'></i> Insight
                                </button>
                            </td>
                        </tr>
                        count++;
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="aiInsightModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-top border-0 border-4 border-info shadow-lg">
            <div class="modal-header bg-light-info">
                <h5 class="modal-title text-info fw-bold"><i class='bx bx-brain me-2'></i> AI Customer Profile: <span id="m_fullname" class="text-dark"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="row align-items-center">
                    <div class="col-lg-5 border-end text-center">
                        <div id="m_segment_badge" class="badge rounded-pill px-4 py-2 fs-5 mb-4 shadow-sm"></div>
                        <ul class="list-group list-group-flush text-start border radius-10">
                            <li class="list-group-item d-flex justify-content-between">Recency <span><b id="m_recency"></b> days</span></li>
                            <li class="list-group-item d-flex justify-content-between">Frequency <span><b id="m_frequency"></b> orders</span></li>
                            <li class="list-group-item d-flex justify-content-between">Monetary <span id="m_monetary" class="fw-bold text-success"></span></li>
                        </ul>
                    </div>
                    <div class="col-lg-7">
                        <div style="height: 300px;">
                            <canvas id="rfmRadarChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/adminassets/plugins/datatable/js/jquery.dataTables.min.js"></script>
    <script src="~/adminassets/plugins/datatable/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        let rfmChart;
        $(document).ready(function() {
            $('#segmentationDataTable').DataTable({
                pageLength: 10,
                order: [[3, "desc"]],
                language: { emptyTable: "No data available in the analysis table." }
            });
        });

        function executeMLTask(url, msg) {
            Swal.fire({ title: msg, text: "AI is processing behavior patterns...", allowOutsideClick: false, didOpen: () => { Swal.showLoading(); } });
            $.post(url, (res) => {
                if(res.success) { Swal.fire({ icon: 'success', title: 'Success', timer: 1500, showConfirmButton: false }).then(() => location.reload()); }
                else { Swal.fire('Error', res.message || 'Analysis failed.', 'error'); }
            });
        }

        function refreshIndividual(userId) {
            $.get('/Admin/CustomerSegmentation/GetUserInsight?userId=' + userId, (data) => {
                $('#m_fullname').text(data.userFullName);
                $('#m_recency').text(data.recency.toFixed(0));
                $('#m_frequency').text(data.frequency);
                $('#m_monetary').text(data.monetary.toLocaleString('en-US', { style: 'currency', currency: 'USD' }).replace('$', '$ '));
                $('#m_segment_badge').text(data.segmentLabel).css({'background':'#0dcaf022', 'color':'#0dcaf0', 'border':'1px solid #0dcaf0'});

                const ctx = document.getElementById('rfmRadarChart').getContext('2d');
                if(rfmChart) rfmChart.destroy();
                rfmChart = new Chart(ctx, {
                    type: 'radar',
                    data: {
                        labels: ['Recency', 'Frequency', 'Monetary'],
                        datasets: [{
                            label: 'DNA Pattern',
                            data: [Math.max(0, 365 - data.recency), data.frequency * 10, Math.log10(data.monetary + 1) * 40],
                            backgroundColor: 'rgba(13, 202, 240, 0.2)', borderColor: '#0dcaf0', borderWidth: 3
                        }]
                    },
                    options: { scales: { r: { ticks: { display: false }, suggestedMin: 0 } }, plugins: { legend: { display: false } } }
                });
                $('#aiInsightModal').modal('show');
            });
        }
    </script>
}
@using Core_Layer.Dtos.CustomerSegmentationDtos
@model List<CustomerSegmentResultDto>

@{
    ViewData["Title"] = "AI Customer Insights";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int count = 1;
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">SmartShopper AI</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item"><a href="javascript:;"><i class="bx bx-chip"></i></a></li>
                <li class="breadcrumb-item active" aria-current="page">Customer Segmentation Analysis</li>
            </ol>
        </nav>
    </div>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-xl-2 mb-4">
    <div class="col">
        <div class="card radius-10 border-start border-0 border-3 border-info">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <p class="mb-0 text-secondary">ML Engine Status</p>
                        <h4 class="my-1 text-info">K-Means Clustering</h4>
                        <p class="mb-0 font-13 text-success"><i class='bx bxs-check-circle'></i> Pipeline is active and ready.</p>
                    </div>
                    <div class="widgets-icons-2 rounded-circle bg-light-info text-info ms-auto">
                        <i class='bx bx-brain'></i>
                    </div>
                </div>
                <div class="mt-3">
                    <button type="button" onclick="executeMLTask('/Admin/CustomerSegmentation/TrainModel', 'Training AI Model...')" class="btn btn-outline-info btn-sm px-3 radius-30">Retrain Model</button>
                    <button type="button" onclick="executeMLTask('/Admin/CustomerSegmentation/ProcessBatch', 'Segmenting Customers...')" class="btn btn-info btn-sm px-3 radius-30 text-white">Update All Segments</button>
                </div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card radius-10 border-start border-0 border-3 border-warning">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <p class="mb-0 text-secondary">Analysed Customer Base</p>
                        <h4 class="my-1 text-warning">@(Model?.Count ?? 0) Users</h4>
                        <p class="mb-0 font-13">Last Refresh: @(Model?.FirstOrDefault()?.LastUpdated.ToString("g") ?? "No Data")</p>
                    </div>
                    <div class="widgets-icons-2 rounded-circle bg-light-warning text-warning ms-auto">
                        <i class='bx bx-group'></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card radius-10">
    <div class="card-body">
        <div class="d-flex align-items-center mb-3">
            <h6 class="mb-0 text-uppercase">Segmentation Results (RFM Analysis)</h6>
        </div>

        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5">
                <h5 class="mt-3 text-secondary">No analysis data found yet.</h5>
                <p>Please use the <strong>Retrain Model</strong> button to start.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table id="segmentationDataTable" class="table table-striped table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Customer Profile</th>
                            <th>AI Segment</th>
                            <th>Confidence</th>
                            <th class="text-center">Analysis Date</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@count</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="widgets-icons-2 rounded-circle bg-light text-primary me-2"><i class='bx bxs-user-rectangle'></i></div>
                                        <div>
                                            <h6 class="mb-0 font-14">@item.UserFullName</h6>
                                            <small class="text-muted">UID: @item.AppUserId.ToString().Substring(0, 8)</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="badge rounded-pill p-2 px-3 text-uppercase" style="background-color: @(item.StatusColor)22; color: @item.StatusColor; border: 1px solid @item.StatusColor">
                                        <i class='bx bxs-circle me-1'></i>@item.SegmentLabel
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress w-100" style="height: 6px;">
                                            <div class="progress-bar" style="width: @(item.ConfidenceScore * 100)%; background-color: @item.StatusColor"></div>
                                        </div>
                                        <span class="font-13 text-secondary">%@((item.ConfidenceScore * 100).ToString("F1"))</span>
                                    </div>
                                </td>
                                <td class="text-center">@item.LastUpdated.ToString("dd.MM.yyyy HH:mm")</td>
                                <td class="text-center">
                                    <div class="d-flex order-actions justify-content-center">
                                        <a href="javascript:;" class="text-primary bg-light-primary border-0" onclick="refreshIndividual('@item.AppUserId')" title="Live Analysis"><i class='bx bx-refresh'></i></a>
                                    </div>
                                </td>
                            </tr>
                            count++;
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="aiInsightModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-top border-0 border-4 border-info">
            <div class="modal-header">
                <h5 class="modal-title text-info"><i class='bx bx-brain me-1'></i> AI Customer Profile: <span id="m_fullname" class="fw-bold text-dark"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="row">
                    <div class="col-lg-5 border-end">
                        <div class="text-center mb-4">
                            <div class="p-3 rounded-circle bg-light-info text-info d-inline-block mb-3"><i class='bx bxs-user-detail fs-1'></i></div>
                            <h5 class="mb-1">Segment Analysis</h5>
                            <div id="m_segment_badge" class="badge rounded-pill px-4 py-2 fs-6 text-uppercase"></div>
                        </div>
                        <div class="list-group list-group-flush radius-10">
                            <div class="list-group-item d-flex justify-content-between align-items-center bg-transparent">
                                <span><i class='bx bx-time-five me-2 text-primary'></i>Recency</span><span class="fw-bold" id="m_recency"></span>
                            </div>
                            <div class="list-group-item d-flex justify-content-between align-items-center bg-transparent">
                                <span><i class='bx bx-repost me-2 text-success'></i>Frequency</span><span class="fw-bold" id="m_frequency"></span>
                            </div>
                            <div class="list-group-item d-flex justify-content-between align-items-center bg-transparent">
                                <span><i class='bx bx-wallet me-2 text-warning'></i>Monetary</span><span class="fw-bold" id="m_monetary"></span>
                            </div>
                            <div class="list-group-item d-flex justify-content-between align-items-center bg-transparent">
                                <span><i class='bx bx-bullseye me-2 text-danger'></i>AI Confidence</span><span class="fw-bold text-danger" id="m_confidence"></span>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-7 text-center">
                        <h6 class="mb-3 text-secondary text-uppercase font-13">RFM Behavioral Fingerprint</h6>
                        <div style="height: 300px; width: 100%;"><canvas id="rfmRadarChart"></canvas></div>
                        <p class="mt-3 small text-muted"><i class='bx bx-info-circle'></i> This chart represents the user's DNA relative to the base.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/adminassets/plugins/datatable/js/jquery.dataTables.min.js"></script>
    <script src="~/adminassets/plugins/datatable/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        let rfmChart;
        $(document).ready(function () {
            $('#segmentationDataTable').DataTable({ pageLength: 10, order: [[4, "desc"]] });
        });

        function executeMLTask(url, loadingMessage) {
            Swal.fire({
                title: 'Are you sure?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#0dcaf0',
                confirmButtonText: 'Start'
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({ title: loadingMessage, allowOutsideClick: false, didOpen: () => { Swal.showLoading(); } });
                    $.post(url, function (res) {
                        if (res.success) {
                            Swal.fire({ icon: 'success', title: 'Success', timer: 2000, showConfirmButton: false }).then(() => { location.reload(); });
                        } else {
                            Swal.fire('Failed', res.message, 'error');
                        }
                    });
                }
            });
        }

        function refreshIndividual(userId) {
            Swal.fire({ title: 'Consulting AI...', allowOutsideClick: false, didOpen: () => { Swal.showLoading(); } });
            $.get('/Admin/CustomerSegmentation/GetUserInsight?userId=' + userId, function (data) {
                Swal.close();
                $('#m_fullname').text(data.userFullName);
                $('#m_recency').text(data.recency.toFixed(0) + ' Days');
                $('#m_frequency').text(data.frequency + ' Orders');
                $('#m_monetary').text(new Intl.NumberFormat('tr-TR', { style: 'currency', currency: 'TRY' }).format(data.monetary));
                $('#m_confidence').text('%' + (data.confidenceScore * 100).toFixed(1));

                const badge = $('#m_segment_badge').text(data.segmentLabel);
                badge.css({ 'background-color': 'rgba(13, 202, 240, 0.2)', 'color': '#0dcaf0', 'border': '1px solid #0dcaf0' });

                renderRadarChart(data);
                $('#aiInsightModal').modal('show');
            });
        }

        function renderRadarChart(data) {
            const ctx = document.getElementById('rfmRadarChart').getContext('2d');
            if (rfmChart) rfmChart.destroy();
            rfmChart = new Chart(ctx, {
                type: 'radar',
                data: {
                    labels: ['Recency', 'Frequency', 'Monetary'],
                    datasets: [{
                        label: 'Customer DNA',
                        data: [Math.max(0, 365 - data.recency), data.frequency * 10, data.monetary / 100],
                        backgroundColor: 'rgba(13, 202, 240, 0.2)',
                        borderColor: 'rgb(13, 202, 240)',
                        borderWidth: 3
                    }]
                },
                options: { scales: { r: { suggestedMin: 0, ticks: { display: false } } }, plugins: { legend: { display: false } } }
            });
        }
    </script>
}
@using Core_Layer.Dtos.ProductForecastDtos
@model List<ProductSalesForecastDto>

@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery

@{
    ViewData["Title"] = "AI Inventory & Stock Planning";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    int totalItemsToStock = Model?.Sum(x => x.PredictedQuantity) ?? 0;
    var mostDemandedProduct = Model?.OrderByDescending(x => x.PredictedQuantity).FirstOrDefault();
    decimal totalProjectedStockValue = Model?.Sum(x => x.ExpectedRevenue) ?? 0;

    // Controller'dan gelen kalite metriklerini DTO olarak yakalıyoruz
    var metrics = ViewBag.ModelMetrics as ProductForecastEvaluationReportDto;
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-4">
    <div class="breadcrumb-title pe-3">SmartShopper AI</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item"><a href="javascript:;"><i class="bx bx-package"></i></a></li>
                <li class="breadcrumb-item active" aria-current="page">Product Demand Planning</li>
            </ol>
        </nav>
    </div>
</div>

@Html.AntiForgeryToken()

<div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 mb-4">

    <div class="col">
        <div class="card radius-10 border-start border-0 border-3 border-info shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-2">
                    <div>
                        <p class="mb-0 text-secondary">AI Prediction Engine</p>
                        <h5 class="my-1 text-info">FastTree Regression</h5>
                        <p class="mb-0 font-13 text-success"><i class='bx bxs-check-shield'></i> Price Elasticity Aware</p>
                    </div>
                    <div class="widgets-icons-2 rounded-circle bg-light-info text-info ms-auto">
                        <i class='bx bx-brain'></i>
                    </div>
                </div>
                <div class="mt-3">
                    <button onclick="executeProductForecast()" class="btn btn-info text-white btn-sm px-4 radius-30 shadow-sm w-100">
                        <i class='bx bx-refresh'></i> Generate Predictions
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card radius-10 border-start border-0 border-3 border-danger shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <p class="mb-0 text-secondary">AI Precision (R-Squared)</p>
                        @if (metrics != null && metrics.RSquaredPercentage > 0)
                        {
                            <h4 class="my-1 text-danger">%@metrics.RSquaredPercentage Accuracy</h4>
                            <p class="mb-0 font-13 text-muted">
                                <strong>MAE:</strong> @metrics.MeanAbsoluteError <small>units/product</small>
                            </p>
                        }
                        else
                        {
                            <h4 class="my-1 text-danger">Not Trained</h4>
                            <p class="mb-0 font-13 text-danger">Please run prediction engine.</p>
                        }
                    </div>
                    <div class="widgets-icons-2 rounded-circle bg-light-danger text-danger ms-auto">
                        <i class='bx bx-target-lock'></i>
                    </div>
                </div>
                @if (metrics != null && metrics.RSquaredPercentage > 0)
                {
                    <div class="mt-2">
                        <small class="text-muted" style="font-size: 11px;"><i class='bx bx-time'></i> Last Eval: @metrics.EvaluatedAt.ToString("dd MMM yyyy HH:mm")</small>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card radius-10 border-start border-0 border-3 border-warning shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <p class="mb-0 text-secondary">Total Units Predicted</p>
                        <h4 class="my-1 text-warning">@totalItemsToStock Units</h4>
                        <p class="mb-0 font-13">Forecasted Sales Volume</p>
                    </div>
                    <div class="widgets-icons-2 rounded-circle bg-light-warning text-warning ms-auto">
                        <i class='bx bx-cart-add'></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card radius-10 border-start border-0 border-3 border-success shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <p class="mb-0 text-secondary">Hot Product Next Month</p>
                        <h5 class="my-1 text-success text-truncate" style="max-width: 150px;" title="@(mostDemandedProduct?.ProductName ?? "N/A")">
                            @(mostDemandedProduct?.ProductName ?? "N/A")
                        </h5>
                        <p class="mb-0 font-13">Target: @(mostDemandedProduct?.PredictedQuantity ?? 0) sales</p>
                    </div>
                    <div class="widgets-icons-2 rounded-circle bg-light-success text-success ms-auto">
                        <i class='bx bx-trending-up'></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card radius-10 shadow-none border">
    <div class="card-header bg-transparent border-bottom">
        <h6 class="mb-0 fw-bold">AI Product Sales & Inventory Forecast Table</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table id="productForecastTable" class="table align-middle mb-0 table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Product Details</th>
                        <th>Current Price</th>
                        <th>Predicted Sales</th>
                        <th>Expected Revenue</th>
                        <th>Stock Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="p-2 border rounded me-2 bg-light-primary text-primary">
                                            <i class='bx bx-barcode-reader fs-4'></i>
                                        </div>
                                        <div>
                                            <h6 class="mb-0 font-14 fw-bold">@item.ProductName</h6>
                                            <small class="text-muted">Target: @item.Period</small>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="fw-bold">$@item.CurrentPrice.ToString("N2")</span></td>
                                <td><h6 class="mb-0 fw-bold">@item.PredictedQuantity Units</h6></td>
                                <td><h6 class="mb-0 text-success fw-bold">$@item.ExpectedRevenue.ToString("N2")</h6></td>
                                <td>
                                    @if (item.StockAction.Contains("Urgent"))
                                    {
                                        <span class="badge bg-light-danger text-danger border border-danger px-3 radius-30">@item.StockAction</span>
                                    }
                                    else if (item.StockAction.Contains("Normal"))
                                    {
                                        <span class="badge bg-light-warning text-warning border border-warning px-3 radius-30">@item.StockAction</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light-info text-info border border-info px-3 radius-30">@item.StockAction</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <i class='bx bx-data fs-1 text-muted mb-2'></i>
                                <h6>No forecast data available.</h6>
                                <p class="text-muted">Click "Generate Predictions" to run the FastTree ML model.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/adminassets/plugins/datatable/js/jquery.dataTables.min.js"></script>
    <script src="~/adminassets/plugins/datatable/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            $('#productForecastTable').DataTable({
                order: [[2, "desc"]],
                pageLength: 10
            });
        });

        function executeProductForecast() {
            Swal.fire({
                title: 'AI Analysis in Progress',
                html: 'Building FastTree regression models and calculating <b>Price Elasticity</b> for all products...<br><br><b>Please wait.</b>',
                allowOutsideClick: false,
                didOpen: () => { Swal.showLoading(); }
            });

            var token = $('input[name="__RequestVerificationToken"]').val();

            $.ajax({
                url: '@Url.Action("RunProductForecast", "ProductSalesForecast", new { area = "Admin" })',
                type: 'POST',
                data: { __RequestVerificationToken: token },
                success: function (res) {
                    if (res.success) {
                        Swal.fire({ icon: 'success', title: 'Calculated!', text: res.message, timer: 2000, showConfirmButton: false })
                        .then(() => { location.reload(); });
                    } else {
                        Swal.fire('Warning', res.message, 'warning');
                    }
                },
                error: function () { Swal.fire('Error', 'Analysis failed.', 'error'); }
            });
        }
    </script>
}
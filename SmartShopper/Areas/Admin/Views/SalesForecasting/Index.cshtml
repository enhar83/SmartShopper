@using Core_Layer.Dtos.SalesForecastDtos
@{
    ViewData["Title"] = "Sales Forecasting Analysis";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    // Controller'dan gelen hata karnesini karşılıyoruz
    var metrics = ViewBag.ModelMetrics as ForecastEvaluationReportDto;
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">SmartShopper AI</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item"><a href="javascript:;"><i class="bx bx-line-chart"></i></a></li>
                <li class="breadcrumb-item active" aria-current="page">Revenue Forecasting & Projections</li>
            </ol>
        </nav>
    </div>
</div>

<div class="row row-cols-1 row-cols-md-3 row-cols-xl-3 mb-4">
    <div class="col">
        <div class="card radius-10 border-start border-0 border-3 border-primary h-100 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div>
                        <p class="mb-0 text-secondary">AI Forecasting Engine</p>
                        <h5 class="my-1 text-primary">Singular Spectrum Analysis</h5>
                        <p class="mb-0 font-13 text-success"><i class='bx bxs-zap'></i> Time Series Core Active</p>
                    </div>
                    <div class="widgets-icons-2 rounded-circle bg-light-primary text-primary ms-auto">
                        <i class='bx bx-trending-up'></i>
                    </div>
                </div>
                <button onclick="trainForecastModel()" class="btn btn-primary btn-sm w-100 radius-30 shadow-sm">
                    <i class='bx bx-refresh'></i> Retrain Forecast Model
                </button>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card radius-10 border-start border-0 border-3 border-success h-100 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <p class="mb-0 text-secondary">AI Precision (Hata Payı)</p>
                        @if (metrics != null && metrics.MeanAbsolutePercentageError > 0)
                        {
                            <h4 class="my-1 text-success">% @metrics.MeanAbsolutePercentageError.ToString("0.00") Error</h4>
                            <p class="mb-0 font-13 text-muted">
                                Monthly Average Deviation: <b>$ @metrics.MeanAbsoluteError.ToString("N0")</b>
                            </p>
                        }
                        else
                        {
                            <h4 class="my-1 text-danger">Not Trained</h4>
                            <p class="mb-0 font-13 text-danger">Please retrain the model.</p>
                        }
                    </div>
                    <div class="widgets-icons-2 rounded-circle bg-light-success text-success ms-auto">
                        <i class='bx bx-target-lock'></i>
                    </div>
                </div>
                @if (metrics != null && metrics.MeanAbsolutePercentageError > 0)
                {
                    <div class="mt-2">
                        <small class="text-muted" style="font-size: 11px;"><i class='bx bx-time'></i> Last Evaluation: @metrics.EvaluatedAt.ToString("dd MMM yyyy HH:mm")</small>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card radius-10 border-start border-0 border-3 border-warning h-100 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <p class="mb-0 text-secondary">Root Mean Squared Error</p>
                        <h4 class="my-1 text-warning">$ @(metrics?.RootMeanSquaredError.ToString("N0") ?? "0")</h4>
                        <p class="mb-0 font-13 text-muted">
                            Statistical Maximum Deviation Tolerance
                        </p>
                    </div>
                    <div class="widgets-icons-2 rounded-circle bg-light-warning text-warning ms-auto">
                        <i class='bx bx-error'></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card radius-10 shadow-sm border">
    <div class="card-header bg-transparent">
        <div class="d-flex align-items-center">
            <div>
                <h6 class="mb-0 text-uppercase fw-bold"><i class='bx bx-chart me-1'></i>Sales Performance & AI Predictions</h6>
            </div>
            <div class="ms-auto">
                <select class="form-select form-select-sm radius-30" id="monthSelector" onchange="loadForecast()">
                    <option value="3">3 Months Prediction</option>
                    <option value="6" selected>6 Months Prediction</option>
                    <option value="12">12 Months Prediction</option>
                </select>
            </div>
        </div>
    </div>
    <div class="card-body">
        <div class="chart-container-0" style="height: 450px;">
            <canvas id="salesForecastChart"></canvas>
        </div>
    </div>
    <div class="card-footer bg-transparent border-top">
        <div class="d-flex align-items-center justify-content-center gap-4 py-2">
            <div class="d-flex align-items-center"><i class='bx bxs-circle me-1 text-primary'></i> <span class="small">Historical Actuals</span></div>
            <div class="d-flex align-items-center"><i class='bx bxs-circle me-1 text-warning'></i> <span class="small">AI Predicted Revenue</span></div>
            <div class="d-flex align-items-center"><i class='bx bxs-circle me-1' style="color: rgba(255, 193, 7, 0.15);"></i> <span class="small">95% Confidence Interval Corridor</span></div>
        </div>
    </div>
</div>

<div class="card radius-10 shadow-sm border">
    <div class="card-body">
        <div class="d-flex align-items-center mb-3">
            <h6 class="mb-0 text-uppercase fw-bold">Monthly Simulation Breakdown</h6>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="forecastTable">
                <thead class="table-light">
                    <tr>
                        <th>Period</th>
                        <th>Type</th>
                        <th>Actual Revenue</th>
                        <th>AI Predicted Revenue</th>
                        <th>Statistical Confidence Range (Low - High)</th>
                    </tr>
                </thead>
                <tbody id="forecastTableBody">
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        let forecastChart;

        $(document).ready(function () {
            loadForecast();
        });

        function trainForecastModel() {
            Swal.fire({
                title: 'AI Machine Learning Initiated',
                text: 'Analyzing multi-year seasonality trends and constructing SSA forecasting metrics...',
                allowOutsideClick: false,
                didOpen: () => { Swal.showLoading(); }
            });

            $.post('/Admin/SalesForecasting/TrainModel', function(res) {
                if(res.success) {
                    Swal.fire({ icon: 'success', title: 'Success', text: res.message, timer: 1500, showConfirmButton: false })
                    .then(() => location.reload());
                } else {
                    Swal.fire('Error', res.message, 'error');
                }
            }).fail(function() {
                Swal.fire('Server Error', 'Failed to communicate with ML.NET pipeline.', 'error');
            });
        }

        function loadForecast() {
            const months = $('#monthSelector').val();

            Swal.fire({
                title: 'Generating Projections...',
                text: 'Loading simulated future values...',
                allowOutsideClick: false,
                didOpen: () => { Swal.showLoading(); }
            });

            $.get(`/Admin/SalesForecasting/GetForecastData?months=${months}`, function (res) {
                Swal.close();
                if (res.success) {
                    renderChart(res.data);
                    renderTable(res.data);
                } else {
                    Swal.fire('Model Notice', res.message + " Please click 'Retrain Model' to generate first file.", 'warning');
                }
            }).fail(function() {
                Swal.close();
                Swal.fire('Error', 'Failed to pull dataset from server.', 'error');
            });
        }

        function renderChart(data) {
            const ctx = document.getElementById('salesForecastChart').getContext('2d');
            if (forecastChart) forecastChart.destroy();

            const labels = data.map(x => x.period);
            const actuals = data.map(x => x.isForecast === false || x.forecastAmount === x.actualAmount ? x.actualAmount : null);
            const forecasts = data.map(x => x.isForecast === true ? x.forecastAmount : null);
            const upperBounds = data.map(x => x.isForecast === true ? x.upperBound : null);
            const lowerBounds = data.map(x => x.isForecast === true ? x.lowerBound : null);

            forecastChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [
                        {
                            label: 'Historical Actuals',
                            data: actuals,
                            borderColor: '#008cff',
                            backgroundColor: 'rgba(0, 140, 255, 0.08)',
                            fill: true,
                            tension: 0.35,
                            pointRadius: 5,
                            borderWidth: 3
                        },
                        {
                            label: 'AI Forecast',
                            data: forecasts,
                            borderColor: '#ffc107',
                            backgroundColor: 'transparent',
                            borderDash: [6, 4],
                            fill: false,
                            tension: 0.35,
                            pointRadius: 5,
                            pointBackgroundColor: '#fff',
                            borderWidth: 3
                        },
                        {
                            label: 'Upper Boundary',
                            data: upperBounds,
                            borderColor: 'transparent',
                            backgroundColor: 'transparent',
                            pointRadius: 0,
                            fill: false
                        },
                        {
                            label: 'Confidence Interval Area',
                            data: lowerBounds,
                            borderColor: 'transparent',
                            backgroundColor: 'rgba(255, 193, 7, 0.12)', // Şık şeffaf sarı koridor
                            pointRadius: 0,
                            fill: '-1' // Üst sınırla (dataset index -1) arasını kaplar
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    let label = context.dataset.label || '';
                                    if (label && label !== 'Upper Boundary' && label !== 'Confidence Interval Area') {
                                        label += ': ';
                                        if (context.parsed.y !== null) {
                                            label += '$ ' + context.parsed.y.toLocaleString();
                                        }
                                        return label;
                                    }
                                    return null;
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: false,
                            grid: { display: true, color: '#f5f5f5' },
                            ticks: { callback: value => '$ ' + value.toLocaleString() }
                        },
                        x: { grid: { display: false } }
                    }
                }
            });
        }

        function renderTable(data) {
            let html = '';
            data.forEach(item => {
                const isForecast = item.isForecast;
                // Köprü noktasının tabloda çift görünmesini engellemek için temiz filtreleme yapıyoruz
                let displayForecast = isForecast && item.actualAmount === 0;

                html += `
                    <tr>
                        <td><span class="fw-bold">${item.period}</span></td>
                        <td>
                            <span class="badge rounded-pill ${displayForecast ? 'bg-light-warning text-warning' : 'bg-light-primary text-primary'} px-3">
                                ${displayForecast ? 'AI PREDICTION' : 'HISTORICAL'}
                            </span>
                        </td>
                        <td><span class="text-primary fw-bold">${item.actualAmount > 0 ? '$ ' + item.actualAmount.toLocaleString() : '-'}</span></td>
                        <td><span class="text-warning fw-bold">${displayForecast ? '$ ' + item.forecastAmount.toLocaleString() : '-'}</span></td>
                        <td>
                            <span class="text-muted small">
                                ${displayForecast ? `$ ${item.lowerBound.toLocaleString()} - $ ${item.upperBound.toLocaleString()}` : '-'}
                            </span>
                        </td>
                    </tr>
                `;
            });
            $('#forecastTableBody').html(html);
        }
    </script>
}
@using Core_Layer.Dtos.DemandForecastDtos
@model List<SubCategoryDemandForecastDto>

@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery

@{
    ViewData["Title"] = "AI SubCategory Demand Forecast";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    decimal totalExpectedRevenue = Model?.Sum(x => x.PredictedRevenue) ?? 0;
    int totalExpectedSales = Model?.Sum(x => x.PredictedSalesCount) ?? 0;
    var topSubCategory = Model?.OrderByDescending(x => x.PredictedRevenue).FirstOrDefault();

    // Controller'dan gelen kalite metriklerini DTO olarak yakalıyoruz
    var metrics = ViewBag.ModelMetrics as DemandForecastEvaluationReportDto;
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-4">
    <div class="breadcrumb-title pe-3">SmartShopper AI</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item"><a href="javascript:;"><i class="bx bx-trending-up"></i></a></li>
                <li class="breadcrumb-item active" aria-current="page">SubCategory Demand Forecasting</li>
            </ol>
        </nav>
    </div>
</div>

@Html.AntiForgeryToken()

<div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 mb-4">
    <div class="col">
        <div class="card radius-10 border-start border-0 border-3 border-info shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-2">
                    <div>
                        <p class="mb-0 text-secondary">AI Forecasting Engine</p>
                        <h5 class="my-1 text-info">FastTree Regression</h5>
                        <p class="mb-0 font-13 text-success"><i class='bx bxs-check-shield'></i> Algorithm Ready</p>
                    </div>
                    <div class="widgets-icons-2 rounded-circle bg-light-info text-info ms-auto"><i class='bx bx-brain'></i></div>
                </div>
                <div class="mt-3">
                    <button onclick="executeDemandForecast()" class="btn btn-info text-white btn-sm px-4 radius-30 shadow-sm w-100">
                        <i class='bx bx-refresh'></i> Generate Forecast
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card radius-10 border-start border-0 border-3 border-danger shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <p class="mb-0 text-secondary">AI Precision (R-Squared)</p>
                        @if (metrics != null && metrics.RSquaredPercentage > 0)
                        {
                            <h4 class="my-1 text-danger">%@metrics.RSquaredPercentage Accuracy</h4>
                            <p class="mb-0 font-13 text-muted">
                                <strong>MAE:</strong> @metrics.MeanAbsoluteError <small>units/category</small>
                            </p>
                        }
                        else
                        {
                            <h4 class="my-1 text-danger">Not Trained</h4>
                            <p class="mb-0 font-13 text-danger">Please run prediction engine.</p>
                        }
                    </div>
                    <div class="widgets-icons-2 rounded-circle bg-light-danger text-danger ms-auto"><i class='bx bx-target-lock'></i></div>
                </div>
                @if (metrics != null && metrics.RSquaredPercentage > 0)
                {
                    <div class="mt-2">
                        <small class="text-muted" style="font-size: 11px;"><i class='bx bx-time'></i> Last Eval: @metrics.EvaluatedAt.ToString("dd MMM yyyy HH:mm")</small>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card radius-10 border-start border-0 border-3 border-success shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <p class="mb-0 text-secondary">Total Projected Revenue</p>
                        <h4 class="my-1 text-success">$ @totalExpectedRevenue.ToString("N2")</h4>
                        <p class="mb-0 font-13">Across @(Model?.Count ?? 0) SubCategories</p>
                    </div>
                    <div class="widgets-icons-2 rounded-circle bg-light-success text-success ms-auto"><i class='bx bx-dollar'></i></div>
                </div>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card radius-10 border-start border-0 border-3 border-primary shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <p class="mb-0 text-secondary">Top Growth SubCategory</p>
                        <h5 class="my-1 text-primary text-truncate" style="max-width: 150px;" title="@(topSubCategory?.SubCategoryName ?? "N/A")">
                            @(topSubCategory != null ? topSubCategory.SubCategoryName : "N/A")
                        </h5>
                        <p class="mb-0 font-13">Expected: $ @(topSubCategory?.PredictedRevenue.ToString("N2") ?? "0.00")</p>
                    </div>
                    <div class="widgets-icons-2 rounded-circle bg-light-primary text-primary ms-auto"><i class='bx bx-purchase-tag-alt'></i></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card radius-10 shadow-none border">
    <div class="card-header bg-transparent border-bottom d-flex align-items-center justify-content-between">
        <h6 class="mb-0 fw-bold">Predicted Category Demands</h6>

        <div class="ms-auto" style="width: 250px;">
            <select id="categoryFilter" class="form-select form-select-sm border-primary">
                <option value="">-- All Categories --</option>
                @if (ViewBag.Categories != null)
                {
                    foreach (var cat in ViewBag.Categories as List<string>)
                    {
                        <option value="@cat">@cat</option>
                    }
                }
            </select>
        </div>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table id="forecastDataTable" class="table align-middle mb-0 table-hover">
                <thead class="table-light">
                    <tr>
                        <th>SubCategory</th>
                        <th>Category</th>
                        <th>Target Period</th>
                        <th>Expected Sales (Qty)</th>
                        <th>Projected Revenue</th>
                        <th>Market Potential</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm bg-light-primary text-primary rounded-circle p-2 me-2 text-center" style="width:35px; height:35px">
                                            <i class='bx bx-category fs-5'></i>
                                        </div>
                                        <div>
                                            <h6 class="mb-0 font-14 fw-bold">@item.SubCategoryName</h6>
                                            <small class="text-muted">Accuracy: % @item.ModelAccuracyScore</small>
                                        </div>
                                    </div>
                                </td>
                                <td>@item.CategoryName</td>
                                <td>
                                    <span class="badge bg-light-secondary text-secondary border">
                                        <i class='bx bx-calendar'></i> @item.Period
                                    </span>
                                </td>
                                <td>
                                    <span class="fw-bold text-dark fs-5">@item.PredictedSalesCount</span>
                                    <small class="text-muted">units</small>
                                </td>
                                <td>
                                    <h6 class="mb-0 font-14 text-success fw-bold">
                                        $ @item.PredictedRevenue.ToString("N2")
                                    </h6>
                                </td>
                                <td>
                                    @if (item.PotentialLevel == "High Growth")
                                    {
                                        <span class="badge bg-light-success text-success border border-success px-3 radius-30">@item.PotentialLevel</span>
                                    }
                                    else if (item.PotentialLevel == "Stable")
                                    {
                                        <span class="badge bg-light-warning text-warning border border-warning px-3 radius-30">@item.PotentialLevel</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light-info text-info border border-info px-3 radius-30">@item.PotentialLevel</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <i class='bx bx-data fs-1 text-muted mb-2'></i>
                                <h6>No forecast data available.</h6>
                                <p class="text-muted">Click "Generate Forecast" to run the ML.NET prediction engine.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/adminassets/plugins/datatable/js/jquery.dataTables.min.js"></script>
    <script src="~/adminassets/plugins/datatable/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            var table = $('#forecastDataTable').DataTable({
                order: [[4, "desc"]], // Projected Revenue'a göre sıralar
                pageLength: 10,
                columnDefs: [
                    { targets: 1, visible: true }
                ]
            });

            $('#categoryFilter').on('change', function () {
                var selectedCategory = $(this).val();

                if (selectedCategory) {
                    table.column(1).search('^' + selectedCategory + '$', true, false).draw();
                } else {
                    table.column(1).search('').draw();
                }
            });
        });

        function executeDemandForecast() {
            Swal.fire({
                title: 'Training ML Model...',
                html: 'Analyzing historical product sales and building FastTree regression model.<br><br><b>Please wait.</b>',
                allowOutsideClick: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            var token = $('input[name="__RequestVerificationToken"]').val();

            $.ajax({
                url: '@Url.Action("RunForecast", "SubCategoryDemandForecast", new { area = "Admin" })',
                type: 'POST',
                data: {
                    __RequestVerificationToken: token
                },
                success: function (res) {
                    if (res.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Forecast Generated!',
                            text: res.message,
                            timer: 2500,
                            showConfirmButton: false
                        }).then(() => {
                            location.reload();
                        });
                    } else {
                        Swal.fire('Warning', res.message, 'warning');
                    }
                },
                error: function (xhr) {
                    Swal.fire('Server Error', 'Could not run the analysis. Check console for details.', 'error');
                }
            });
        }
    </script>
}
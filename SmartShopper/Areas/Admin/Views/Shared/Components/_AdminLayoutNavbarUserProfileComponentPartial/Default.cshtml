@using SmartShopper.Areas.Admin.Models
@model AdminNavbarUserProfileViewModel

<div class="user-box dropdown">
    <a class="d-flex align-items-center nav-link dropdown-toggle dropdown-toggle-nocaret" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">

        @if (!string.IsNullOrEmpty(Model.ImageUrl) && Model.ImageUrl != "/adminassets/images/avatars/default.png")
        {
            <img src="@Model.ImageUrl" class="user-img-custom" alt="user avatar">
        }
        else
        {
            <div class="user-initials-custom">
                @Model.Initials
            </div>
        }

        <div class="user-info ps-3">
            <p class="user-name mb-0">@Model.FullName</p>
            <p class="designattion mb-0">@Model.RoleName</p>
        </div>
    </a>
    <ul class="dropdown-menu dropdown-menu-end">
        <li>
            <a class="dropdown-item" href="/Admin/Profile/Index"><i class="bx bx-user"></i><span>Profile</span></a>
        </li>
        <li>
            <div class="dropdown-divider mb-0"></div>
        </li>
        <li>
            <a class="dropdown-item" href="/Auth/Logout"><i class='bx bx-log-out-circle'></i><span>Logout</span></a>
        </li>
    </ul>
</div>

<style>
    .user-img-custom {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid #e0e0e0;
    }

    .user-initials-custom {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: linear-gradient(45deg, #6a11cb 0%, #2575fc 100%);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 14px;
        text-transform: uppercase;
        border: 1px solid #fff;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    .dropdown-item i {
        vertical-align: middle;
        margin-right: 8px;
    }
</style>
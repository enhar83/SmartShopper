@using Core_Layer.Dtos.ProductDtos
@model List<ProductListDtoAdminPanel>

@{
    ViewData["Title"] = "Product Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-xl-12 mx-auto">
        <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
            <div class="breadcrumb-title pe-3">Product Management</div>
            <div class="ms-auto">
                <button type="button" class="btn btn-primary px-4" onclick="openProductModal()">
                    <i class='bx bx-plus-circle'></i> Add New Product
                </button>
            </div>
        </div>

        <h6 class="mb-0 text-uppercase">Existing Products</h6>
        <hr />

        <div class="card border-top border-0 border-4 border-primary">
            <div class="card-body">
                <div class="table-responsive">
                    @if (Model != null && Model.Any())
                    {
                        <table id="productDataTable" class="table table-striped table-bordered align-middle" style="width:100%">
                            <thead>
                                <tr>
                                    <th style="width: 5%">#</th>
                                    <th>Name</th>
                                    <th>Price</th>
                                    <th>Stock</th>
                                    <th>Category Name</th>
                                    <th>Subcategory Name</th>
                                    <th>Gender</th>
                                    <th class="text-center">Status</th>
                                    <th>Created Date</th>
                                    <th class="text-center">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int count = 1;
                                }
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@count</td>
                                        <td><strong>@item.Name</strong></td>
                                        <td>@item.Price.ToString("C2")</td>
                                        <td>
                                            <span class="badge @(item.Stock <= 5 ? "bg-light-warning text-warning" : "text-dark")">
                                                @item.Stock
                                            </span>
                                        </td>
                                        <td>@item.CategoryName</td>
                                        <td>@item.SubCategoryName</td>
                                        <td>
                                            <span class="badge bg-info">@(item.Gender?.ToString() ?? "N/A")</span>
                                        </td>
                                        <td class="text-center">
                                            @if (!item.IsDeleted)
                                            {
                                                <span class="text-success h4" title="Active"><i class='bx bxs-check-shield'></i></span>
                                            }
                                            else
                                            {
                                                <span class="text-danger h4" title="Passive"><i class='bx bxs-error-alt'></i></span>
                                            }
                                        </td>
                                        <td>@item.CreatedDate.ToShortDateString()</td>
                                        <td class="text-center">
                                            <div class="d-flex order-actions justify-content-center">
                                                <a href="javascript:;" onclick="openImageModal('@item.Id', '@item.Name')" class="text-success bg-light-success border-0 me-2" title="Manage Images">
                                                    <i class='bx bx-images'></i>
                                                </a>
                                                <a href="javascript:;" onclick="editProduct('@item.Id')" class="text-primary bg-light-primary border-0" title="Edit">
                                                    <i class='bx bxs-edit'></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                    count++;
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="productModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-top border-0 border-4 border-primary">
            <div class="modal-header">
                <h5 class="modal-title text-primary" id="modalHeaderTitle"><i class="bx bxs-box me-1"></i>Product Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="productForm">
                <input type="hidden" name="Id" id="productId" />
                <div class="modal-body p-4">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-bold">Product Name</label>
                            <input name="Name" id="productName" type="text" class="form-control" required>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold">Description</label>
                            <textarea name="Description" id="productDescription" class="form-control" rows="2" required></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-primary">Main Category</label>
                            <select id="mainCategorySelect" class="form-select border-primary">
                                <option value="">-- Select Category --</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-success">SubCategory</label>
                            <select name="SubCategoryId" id="subCategorySelect" class="form-select border-success" disabled required>
                                <option value="">-- Choose Sub --</option>
                            </select>
                        </div>
                        <div class="col-12" id="genderContainer" style="display:none;">
                            <label class="form-label fw-bold">Target Gender</label>
                            <select name="Gender" id="genderSelect" class="form-select">
                                <option value="">-- Select Gender --</option>
                                <option value="0">Children</option>
                                <option value="1">Male</option>
                                <option value="2">Female</option>
                                <option value="3">Unisex</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Price</label>
                            <input name="Price" id="productPrice" type="number" step="0.01" class="form-control" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Stock</label>
                            <input name="Stock" id="productStock" type="number" class="form-control" required>
                        </div>

                        <div class="col-md-6" id="isDeletedContainer" style="display:none;">
                            <label class="form-label fw-bold">Status Management</label>
                            <div class="form-check form-switch mt-1">
                                <input class="form-check-input" type="checkbox" id="isDeletedSwitch">
                                <label class="form-check-label text-danger fw-bold">Mark as Passive</label>
                            </div>
                        </div>

                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary px-4 shadow-sm">Save Product</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="imageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-top border-0 border-4 border-success">
            <div class="modal-header">
                <h5 class="modal-title text-success"><i class="bx bx-images me-1"></i>Gallery: <span id="imageModalProductName" class="fw-bold"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="imageUploadForm" enctype="multipart/form-data">
                    <input type="hidden" name="ProductId" id="imageModalProductId" />
                    <div class="card bg-light-success border-0 shadow-none mb-4">
                        <div class="card-body p-3">
                            <div class="row g-2 align-items-end">
                                <div class="col-md-7">
                                    <label class="form-label fw-bold small">Choose Image</label>
                                    <input type="file" name="Photo" class="form-control form-control-sm" accept="image/*" required>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label fw-bold small">Set Main?</label>
                                    <div class="form-check form-switch mt-1">
                                        <input class="form-check-input" type="checkbox" name="IsMain" value="true">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <button type="submit" class="btn btn-success w-100">Save</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>

                <h6 class="mb-3 text-uppercase small fw-bold text-success">Product Photos</h6>
                <div class="row g-3" id="imageGalleryContainer"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/adminassets/plugins/datatable/js/jquery.dataTables.min.js"></script>
    <script src="~/adminassets/plugins/datatable/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        var allCategories = [];
        var saveMode = "Add";

        $(document).ready(function() {
            $('#productDataTable').DataTable({ "pageLength": 10 });

            $("#mainCategorySelect").on("change", function() {
                var selectedId = $(this).val();
                if (!selectedId) { resetCascading(); return; }
                handleGenderVisibility(selectedId);
                loadSubCategoriesByParent(selectedId);
            });

            $("#productForm").on("submit", function (e) {
                e.preventDefault();
                var url = saveMode === "Add" ? '/Admin/Product/AddProduct' : '/Admin/Product/UpdateProduct';

                var formData = $(this).serializeArray();

                if (saveMode === "Update") {
                    var isPassive = $("#isDeletedSwitch").is(":checked");
                    formData = formData.filter(function(item) { return item.name !== "IsDeleted"; });
                    formData.push({ name: "IsDeleted", value: isPassive });
                }

                $.ajax({
                    url: url,
                    type: 'POST',
                    data: $.param(formData),
                    success: function (res) {
                        if (res.success) {
                            Swal.fire({ icon: 'success', title: 'Success', timer: 1000, showConfirmButton: false }).then(() => location.reload());
                        } else { Swal.fire('Error', res.message, 'error'); }
                    }
                });
            });

            $("#imageUploadForm").on("submit", function (e) {
                e.preventDefault();
                var productId = $("#imageModalProductId").val();
                var formData = new FormData(this);

                $.ajax({
                    url: '/Admin/ProductImage/AddProductImage',
                    type: 'POST',
                    data: formData,
                    contentType: false,
                    processData: false,
                    success: function (res) {
                        if (res.success) {
                            Swal.fire({ icon: 'success', title: 'Uploaded!', timer: 800, showConfirmButton: false });
                            $("#imageUploadForm")[0].reset();
                            loadProductImages(productId);
                        } else { Swal.fire('Error', res.message, 'error'); }
                    }
                });
            });
        });

        function openImageModal(id, name) {
            $("#imageModalProductId").val(id);
            $("#imageModalProductName").text(name);
            $("#imageUploadForm")[0].reset();
            loadProductImages(id);
            $("#imageModal").modal("show");
        }

                function loadProductImages(productId) {
            $.get('/Admin/ProductImage/GetProductImages?productId=' + productId, function (res) {
                var html = "";
                if (!res || res.length === 0) {
                    html = `<div class="col-12 text-center py-5">
                                <i class='bx bx-image-add text-muted mb-2' style="font-size: 3rem;"></i>
                                <p class="text-muted">No images found for this product.</p>
                            </div>`;
                } else {
                    res.forEach(img => {
                        var url = img.imageUrl || img.ImageUrl;
                        var isMain = (img.isMain !== undefined) ? img.isMain : img.IsMain;

                        // Dış link değilse başına / ekle
                        if (url && !url.startsWith('/') && !url.startsWith('http')) { url = '/' + url; }

                        html += `<div class="col-md-4 col-sm-6">
                                    <div class="card shadow-none border mb-0 overflow-hidden position-relative">
                                        ${isMain ? '<span class="badge bg-success position-absolute top-0 end-0 m-2" style="z-index:5;">Main</span>' : ''}
                                        <div style="height: 140px; background: #f8f9fa; display: flex; align-items: center; justify-content: center;">
                                            <img src="${url}"
                                                 class="img-fluid"
                                                 style="max-height: 100%; object-fit: contain;"
                                                 loading="lazy"
                                                 onerror="this.onerror=null;this.src='https://placehold.co/800x600?text=No+Image'">
                                        </div>
                                        <div class="card-footer bg-light p-2 text-center">
                                            <button class="btn btn-sm btn-outline-danger border-0" onclick="deleteProductImage('${img.id || img.Id}', '${productId}')" title="Delete">
                                                <i class="bx bx-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>`;
                    });
                }
                $("#imageGalleryContainer").html(html);
            });
        }

        function deleteProductImage(imageId, productId) {
            Swal.fire({
                title: 'Are you sure?',
                text: "Image will be permanently deleted!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Yes, delete!'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/Admin/ProductImage/DeleteProductImage',
                        type: 'POST',
                        data: { id: imageId },
                        success: function (res) {
                            if (res.success) {
                                Swal.fire({ icon: 'success', title: 'Deleted!', timer: 1000, showConfirmButton: false });
                                loadProductImages(productId);
                            } else { Swal.fire('Error!', res.message, 'error'); }
                        }
                    });
                }
            });
        }

        function openProductModal() {
            saveMode = "Add";
            $("#productForm")[0].reset();
            $("#productId").val("");
            $("#modalHeaderTitle").text("Add New Product");
            $("#isDeletedContainer").hide();
            $("#isDeletedSwitch").prop("checked", false);
            resetCascading();
            loadMainCategories();
            $('#productModal').modal('show');
        }

        function editProduct(id) {
            saveMode = "Update";
            $("#productForm")[0].reset();
            $("#modalHeaderTitle").text("Update Product");
            $("#isDeletedContainer").show();

            $.get('/Admin/Category/GetActiveCategories', function (categories) {
                allCategories = categories;
                fillMainCategoryDropdown(categories);
                $.get('/Admin/Product/GetProduct?id=' + id, function (product) {
                    $("#productId").val(product.id || product.Id);
                    $("#productName").val(product.name || product.Name);
                    $("#productDescription").val(product.description || product.Description);
                    $("#productPrice").val(product.price || product.Price);
                    $("#productStock").val(product.stock || product.Stock);

                    var isDeletedVal = (product.isDeleted !== undefined) ? product.isDeleted : product.IsDeleted;
                    $("#isDeletedSwitch").prop("checked", isDeletedVal);

                    var subId = product.subCategoryId || product.SubCategoryId;
                    $.get('/Admin/SubCategory/GetSubCategoryParentId?subId=' + subId, function (parentId) {
                        $("#mainCategorySelect").val(parentId);
                        handleGenderVisibility(parentId);
                        loadSubCategoriesByParent(parentId, subId);
                    });
                    $("#genderSelect").val(product.gender !== null ? product.gender : "");
                    $('#productModal').modal('show');
                });
            });
        }

        function loadMainCategories() {
            $.get('/Admin/Category/GetActiveCategories', function (data) {
                allCategories = data;
                fillMainCategoryDropdown(data);
            });
        }

        function fillMainCategoryDropdown(data) {
            var $select = $("#mainCategorySelect");
            $select.empty().append('<option value="">-- Select Category --</option>');
            data.forEach(cat => $select.append(`<option value="${cat.id}">${cat.name}</option>`));
        }

        function loadSubCategoriesByParent(parentId, selectedSubId = null) {
            $.get('/Admin/SubCategory/GetSubCategoriesByParent?parentId=' + parentId, function (subs) {
                var $subSelect = $("#subCategorySelect");
                $subSelect.empty().append('<option value="">-- Choose Sub --</option>').prop("disabled", false);
                subs.forEach(sub => {
                    if (!sub.isDeleted) $subSelect.append(`<option value="${sub.id}">${sub.name || sub.Name}</option>`);
                });
                if (selectedSubId) $subSelect.val(selectedSubId);
            });
        }

        function handleGenderVisibility(categoryId) {
            var selectedCat = allCategories.find(x => x.id == categoryId);
            if (selectedCat && selectedCat.hasGender) {
                $("#genderContainer").fadeIn();
                $("#genderSelect").attr("required", true);
            } else {
                $("#genderContainer").fadeOut();
                $("#genderSelect").removeAttr("required").val("");
            }
        }

        function resetCascading() {
            $("#subCategorySelect").prop("disabled", true).empty().append('<option value="">-- Choose Sub --</option>');
            $("#genderContainer").hide();
        }
    </script>
}
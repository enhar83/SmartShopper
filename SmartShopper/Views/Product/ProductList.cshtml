@using Core_Layer.Dtos.ProductDtos
@model List<ProductListDto>

@{
    ViewData["Title"] = "Shop";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .single-product {
        border-radius: 4px;
        background: #fff;
        height: 100%;
        overflow: hidden;
    }

    .product-img-container {
        height: 300px;
        position: relative;
        background: #f5f5f5;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

        .product-img-container img {
            transition: transform 0.5s ease;
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .single-product:hover .product-img-container img {
        transform: scale(1.1);
    }

    .subcat-badge {
        position: absolute;
        top: 15px;
        left: 15px;
        padding: 4px 14px;
        font-size: 11px;
        font-weight: 700;
        color: #fff;
        text-transform: uppercase;
        border-radius: 3px;
        z-index: 3;
        letter-spacing: 0.8px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    .stock-status-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        padding: 4px 10px;
        font-size: 10px;
        color: #fff;
        font-weight: 700;
        text-transform: uppercase;
        border-radius: 3px;
        z-index: 3;
    }

    .bg-success {
        background-color: #28a745 !important;
        color: #fff !important;
    }

    .bg-warning {
        background-color: #ffc107 !important;
        color: #000 !important;
    }

    .bg-danger {
        background-color: #dc3545 !important;
        color: #fff !important;
    }

    .product-tag {
        font-size: 13px;
        color: #888;
        margin-bottom: 5px;
    }

    .product-title {
        font-size: 16px;
        font-weight: 600;
        margin-bottom: 8px;
        display: block;
        color: #222;
        text-decoration: none;
    }

    .price-container {
        position: relative;
        height: 30px;
        overflow: hidden;
    }

    .product-price {
        font-size: 15px;
        color: #222;
        font-weight: 500;
        transition: transform 0.3s ease;
        display: block;
    }

    .add-to-cart-btn {
        position: absolute;
        top: 30px;
        left: 0;
        font-size: 13px;
        font-weight: 700;
        color: #e67e22;
        text-transform: uppercase;
        text-decoration: none;
        transition: transform 0.3s ease;
        display: flex;
        align-items: center;
    }

        .add-to-cart-btn i {
            margin-right: 5px;
        }

    .single-product:hover .product-price {
        transform: translateY(-30px);
    }

    .single-product:hover .add-to-cart-btn {
        transform: translateY(-30px);
    }

    .pagination {
        display: flex;
        padding-left: 0;
        list-style: none;
        border-radius: 0.25rem;
    }

    .page-item {
        margin: 0 4px;
    }

    .page-link {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px !important;
        background: #fff;
        color: #333;
        font-weight: 600;
        border: 1px solid #eee !important;
        transition: all 0.2s ease;
        text-decoration: none !important;
    }

        .page-link:hover {
            background-color: #f8f9fa;
            color: #e67e22;
            border-color: #e67e22 !important;
        }

    .page-item.active .page-link {
        background-color: #222 !important;
        border-color: #222 !important;
        color: #fff !important;
    }

    #product-list-container {
        transition: opacity 0.3s ease;
    }

    .subcategory-link.active-sub {
        color: #f39c12 !important;
        font-weight: 700;
    }
</style>

<div class="slider-area over-hidden" style="background: #fcfcfc; padding: 50px 0;">
    <div class="container">
        <div class="row text-center">
            <div class="col-12">
                <h2 class="mb-10">Shop</h2>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb justify-content-center bg-transparent p-0">
                        <li class="breadcrumb-item"><a href="/" style="color:#888;">Home</a></li>
                        <li class="breadcrumb-item active">Shop page</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<div class="right-sidebar-area mt-50">
    <div class="container">
        <div class="row">
            @await Component.InvokeAsync("_CategoryListInSidebarComponentPartial")
            <div class="col-xl-9 col-lg-9 col-md-12">
                <div class="shop-header-area mb-40">
                    <div class="row align-items-center">
                        <div class="col-md-8">
                            <h6 class="mb-0 text-muted" id="filter-info-text">
                                Showing all <span class="theme-color">@Model.Count</span> products
                            </h6>
                        </div>
                        <div class="col-md-4 d-flex justify-content-md-end">
                            <div class="view-mode d-flex align-items-center">
                                <a href="javascript:void(0)" id="gridBtn" class="mr-3 active" style="color:#222;"><i class="fas fa-th"></i></a>
                                <a href="javascript:void(0)" id="listBtn" style="color:#ccc;"><i class="fas fa-list"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
                <div id="product-list-container" class="row"></div>
                <div class="row mt-50 mb-80">
                    <div class="col-12 d-flex justify-content-center">
                        <nav>
                            <ul class="pagination justify-content-center" id="pagination-container"></ul>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const allProducts = @Html.Raw(Json.Serialize(Model));
        let filteredProducts = [...allProducts];
        const pageSize = 12;
        let currentPage = 1;
        let currentView = 'grid';

        const container = document.getElementById("product-list-container");
        const pagination = document.getElementById("pagination-container");
        const filterInfoText = document.getElementById("filter-info-text");

        // URL PARAMETRESİ İLE OTOMATİK FİLTRELEME
        const urlParams = new URLSearchParams(window.location.search);
        const subCategoryParam = urlParams.get('subCategory');

        if (subCategoryParam) {
            const targetName = String(subCategoryParam).toLowerCase().trim();
            filteredProducts = allProducts.filter(p => String(p.subCategoryName || "").toLowerCase().trim() === targetName);
            if(filterInfoText) {
                filterInfoText.innerHTML = `<span class="theme-color">${filteredProducts.length}</span> products in <span class="theme-color">"${subCategoryParam}"</span>`;
            }
            setTimeout(() => {
                document.querySelectorAll('.subcategory-link').forEach(l => {
                    if(l.getAttribute('data-name') === subCategoryParam) {
                        l.classList.add('active-sub');
                    }
                });
            }, 300);
        }

        const subCatColorMap = {};
        const modernColors = ["#d4a373", "#e67e22", "#2ecc71", "#3498db", "#9b59b6", "#e74c3c", "#1abc9c", "#2c3e50", "#27ae60", "#d35400"];

        function getSubCatColor(name) {
            if (!name) return "#999";
            if (!subCatColorMap[name]) {
                const colorIndex = Object.keys(subCatColorMap).length % modernColors.length;
                subCatColorMap[name] = modernColors[colorIndex];
            }
            return subCatColorMap[name];
        }

        function render() {
            container.style.opacity = "0";
            setTimeout(() => {
                const start = (currentPage - 1) * pageSize;
                const end = Math.min(start + pageSize, filteredProducts.length);
                const currentItems = filteredProducts.slice(start, end);
                container.innerHTML = "";
                if (currentItems.length === 0) {
                    container.innerHTML = '<div class="col-12 text-center py-5"><h5>No products found.</h5></div>';
                } else {
                    currentItems.forEach(item => {
                        container.insertAdjacentHTML('beforeend', currentView === 'grid' ? getGridHtml(item) : getListHtml(item));
                    });
                }
                renderPagination();
                container.style.opacity = "1";
            }, 200);
        }

        function getGridHtml(item) {
            const img = (item.mainImageUrl && item.mainImageUrl !== "NO_IMAGE")
                ? `<img src="${item.mainImageUrl}" class="img-fluid">`
                : `<i class="fas fa-image fa-3x text-muted"></i>`;
            const subCatBadgeColor = getSubCatColor(item.subCategoryName);
            const isOutOfStock = item.stockStatus === "Out of Stock";
            const cartBtnHtml = isOutOfStock
                ? `<span class="add-to-cart-btn text-muted" style="cursor:not-allowed; opacity:0.6;"><i class="fas fa-ban"></i> SOLD OUT</span>`
                : `<a href="javascript:void(0)" class="add-to-cart-btn"><i class="fas fa-shopping-basket"></i> ADD TO CART</a>`;

            return `
                <div class="col-xl-4 col-md-6 col-sm-6 mb-5">
                    <div class="single-product">
                        <div class="product-img-container mb-3">
                            <div class="subcat-badge" style="background-color: ${subCatBadgeColor}">${item.subCategoryName || ''}</div>
                            <div class="stock-status-badge ${item.stockStatusClass || ''}">${item.stockStatus || ''}</div>
                            <a href="/Product/ProductDetails/${item.id}" class="w-100 h-100 d-flex align-items-center justify-content-center">${img}</a>
                        </div>
                        <div class="product-tag text-capitalize">${item.categoryName || ''}</div>
                        <a href="/Product/ProductDetails/${item.id}" class="product-title text-capitalize">${item.name}</a>
                        <div class="price-container">
                            <span class="product-price">$${item.price.toFixed(2)}</span>
                            ${cartBtnHtml}
                        </div>
                    </div>
                </div>`;
        }

        function getListHtml(item) {
            const subCatBadgeColor = getSubCatColor(item.subCategoryName);
            const isOutOfStock = item.stockStatus === "Out of Stock";
            const cartBtnHtml = isOutOfStock
                ? `<span class="btn btn-sm btn-secondary disabled mt-2">Sold Out</span>`
                : `<a href="javascript:void(0)" class="add-to-cart-btn">ADD TO CART</a>`;

            return `
                <div class="col-12 mb-4">
                    <div class="single-product p-3">
                        <div class="row align-items-center">
                            <div class="col-md-4">
                                <div class="product-img-container" style="height:200px;">
                                    <div class="stock-status-badge ${item.stockStatusClass}" style="bottom:10px; right:10px; top:auto;">${item.stockStatus}</div>
                                    <img src="${item.mainImageUrl}" class="img-fluid">
                                </div>
                            </div>
                            <div class="col-md-8 px-4">
                                <span class="badge mb-2" style="background-color: ${subCatBadgeColor}; color: #fff; padding: 5px 10px; text-transform: uppercase; font-size: 10px;">${item.subCategoryName}</span>
                                <div class="product-tag text-capitalize">${item.categoryName}</div>
                                <h4 class="mb-2 text-capitalize">${item.name}</h4>
                                <p class="text-muted small mb-3">${item.description || ''}</p>
                                <div class="price-container">
                                    <span class="product-price">$${item.price.toFixed(2)}</span>
                                    ${cartBtnHtml}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>`;
        }

        function renderPagination() {
            const totalPages = Math.ceil(filteredProducts.length / pageSize);
            pagination.innerHTML = "";
            if (totalPages <= 1) return;
            const maxVisible = 2;
            pagination.insertAdjacentHTML('beforeend', `<li class="page-item ${currentPage === 1 ? 'disabled' : ''}"><a class="page-link" href="javascript:void(0)" onclick="goPage(${currentPage - 1})"><i class="fas fa-chevron-left"></i></a></li>`);
            for (let i = 1; i <= totalPages; i++) {
                if (i === 1 || i === totalPages || (i >= currentPage - maxVisible && i <= currentPage + maxVisible)) {
                    pagination.insertAdjacentHTML('beforeend', `<li class="page-item ${i === currentPage ? 'active' : ''}"><a class="page-link" href="javascript:void(0)" onclick="goPage(${i})">${i}</a></li>`);
                } else if (i === currentPage - maxVisible - 1 || i === currentPage + maxVisible + 1) {
                    pagination.insertAdjacentHTML('beforeend', '<li style="display:flex; align-items:center; padding:0 10px; color:#999;">...</li>');
                }
            }
            pagination.insertAdjacentHTML('beforeend', `<li class="page-item ${currentPage === totalPages ? 'disabled' : ''}"><a class="page-link" href="javascript:void(0)" onclick="goPage(${currentPage + 1})"><i class="fas fa-chevron-right"></i></a></li>`);
        }

        window.goPage = function(p) { currentPage = p; render(); window.scrollTo({ top: document.querySelector('.shop-header-area').offsetTop - 50, behavior: 'smooth' }); };

        function filterByCategory(subCategoryName) {
            const targetName = String(subCategoryName).toLowerCase().trim();
            if (!targetName || targetName === "" || targetName === "null") {
                filteredProducts = [...allProducts];
                filterInfoText.innerHTML = `Showing all <span class="theme-color">${allProducts.length}</span> products`;
            } else {
                filteredProducts = allProducts.filter(p => String(p.subCategoryName || "").toLowerCase().trim() === targetName);
                filterInfoText.innerHTML = `<span class="theme-color">${filteredProducts.length}</span> products in <span class="theme-color">"${subCategoryName}"</span>`;
            }
            currentPage = 1; render();
        }

        document.addEventListener('click', function (e) {
            const subLink = e.target.closest('.subcategory-link');
            if (subLink) {
                e.preventDefault();
                document.querySelectorAll('.subcategory-link').forEach(l => l.classList.remove('active-sub'));
                subLink.classList.add('active-sub');
                filterByCategory(subLink.getAttribute('data-name'));
                return;
            }
            const catRow = e.target.closest('.category-row');
            if (catRow) {
                const panel = catRow.nextElementSibling;
                catRow.parentElement.classList.toggle('active-cat');
                panel.style.maxHeight = panel.style.maxHeight ? null : panel.scrollHeight + "px";
            }
        });

        document.getElementById("gridBtn").addEventListener("click", function() { currentView = 'grid'; this.classList.add("active"); document.getElementById("listBtn").classList.remove("active"); render(); });
        document.getElementById("listBtn").addEventListener("click", function() { currentView = 'list'; this.classList.add("active"); document.getElementById("gridBtn").classList.remove("active"); render(); });

        render();
    });
</script>
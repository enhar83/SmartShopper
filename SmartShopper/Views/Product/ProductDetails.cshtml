@using Core_Layer.Dtos.ProductDtos
@model ProductDetailDto

@{
    ViewData["Title"] = "Product Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .thumbnail-slider-wrapper {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100px;
    }

    .p-tap-vertical {
        overflow-y: auto;
        scroll-behavior: smooth;
        max-height: 450px;
        scrollbar-width: none;
    }

        .p-tap-vertical::-webkit-scrollbar {
            display: none;
        }

    .thumb-arrow {
        background: #fff;
        border: 1px solid #eee;
        color: #333;
        width: 100%;
        padding: 5px 0;
        cursor: pointer;
        transition: 0.3s;
        z-index: 5;
    }

        .thumb-arrow:hover {
            background: #f39c12;
            color: #fff;
        }

    .product-thumbnail {
        width: 80px;
        height: 100px;
        object-fit: cover;
        border: 2px solid transparent;
        border-radius: 4px;
        transition: 0.3s;
    }

    .nav-link.active .product-thumbnail {
        border-color: #f39c12;
    }

    .main-img-container {
        width: 100%;
        height: 500px;
        background: #fdfdfd;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        border-radius: 8px;
        border: 1px solid #f0f0f0;
        position: relative;
    }

    .main-product-img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
    }

    .product-view-tab .nav-link {
        font-weight: 600;
        text-transform: uppercase;
        color: #999;
        border: none;
        border-bottom: 2px solid transparent;
        padding: 10px 25px;
    }

        .product-view-tab .nav-link.active {
            color: #333;
            border-bottom: 2px solid #f39c12;
        }

    .related-product-card {
        border: 1px solid #f0f0f0;
        transition: 0.3s;
        border-radius: 8px;
        height: 100%;
    }

        .related-product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.05);
        }

    .related-img-container {
        height: 250px;
        width: 100%;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f9f9f9;
    }


    .stock-badge {
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 14px;
        font-weight: 600;
    }
</style>

<div class="p-page-area">
    <div class="container-wrapper extra-padding-15">
        <div class="row">
            <div class="col-12">
                <div class="page-title pt-40">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb bg-transparent px-0">
                            <li class="breadcrumb-item"><a href="/">Home</a></li>
                            <li class="breadcrumb-item"><a href="/Product/ProductList">Shop</a></li>
                            <li class="breadcrumb-item active">@Model.Name</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="shop-single-page-area over-hidden">
    <div class="container-wrapper extra-padding-15">
        <div class="p-view-position">
            <div class="row">
                <div class="col-xl-6 col-lg-6 col-md-12 mt-10">
                    <div class="product-left-img-tab d-flex">
                        <div class="thumbnail-slider-wrapper">
                            <button class="thumb-arrow" id="scrollUp"><i class="fas fa-chevron-up"></i></button>
                            <div class="nav flex-column nav-pills p-tap-vertical" id="v-pills-tab" role="tablist">
                                @if (Model.ProductImages != null)
                                {
                                    int i = 0;
                                    foreach (var img in Model.ProductImages)
                                    {
                                        <a class="nav-link mb-2 @(i == 0 ? "active" : "")" id="tab-@i" data-toggle="pill" href="#img-view-@i" role="tab">
                                            <img class="product-thumbnail" src="@img.ImageUrl" alt="Thumb">
                                        </a>
                                        i++;
                                    }
                                }
                            </div>
                            <button class="thumb-arrow" id="scrollDown"><i class="fas fa-chevron-down"></i></button>
                        </div>
                        <div class="tab-content width100 text-center ml-20" id="v-pills-tabContent">
                            @if (Model.ProductImages != null)
                            {
                                int j = 0;
                                foreach (var img in Model.ProductImages)
                                {
                                    <div class="tab-pane fade @(j == 0 ? "show active" : "")" id="img-view-@j" role="tabpanel">
                                        <div class="main-img-container">
                                            <div class="product-gallery-btn position-absolute" style="right: 15px; top: 15px; z-index: 10;">
                                                <a href="@img.ImageUrl" class="zoom-gallery bg-white p-2 shadow-sm rounded-circle" data-fancybox="images">
                                                    <i class="fas fa-search text-dark"></i>
                                                </a>
                                            </div>
                                            <img class="main-product-img" src="@img.ImageUrl" alt="@Model.Name">
                                        </div>
                                    </div>
                                    j++;
                                }
                            }
                        </div>
                    </div>
                </div>

                <div class="col-xl-6 col-lg-6 col-md-12">
                    <div class="product-view-info mt-20 pl-30">
                        <div class="single-product-tag mb-10">
                            <span class="text-muted">@Model.CategoryName / @Model.SubCategoryName</span>
                        </div>
                        <h2 class="mb-20">@Model.Name</h2>
                        <div class="p-info-img-price mb-20">
                            <h3 class="theme-color">@Model.Price.ToString("C2")</h3>
                        </div>
                        <p class="mb-30">@Model.Description</p>

                        <div class="all-info d-sm-flex align-items-center border-t-light-gray border-b-light-gray pb-40 pt-30">
                            <div class="quick-add-to-cart d-flex align-items-center">
                                <div class="quantity-field mr-20">
                                    <input type="number" value="1" min="1" class="form-control text-center" style="width: 70px; height: 50px;"
                                           @(Model.StockStatus == "Out of Stock" ? "disabled" : "")>
                                </div>

                                @if (Model.StockStatus == "Out of Stock")
                                {
                                    <button class="btn btn-secondary px-5 py-3 text-uppercase" disabled>Out of Stock</button>
                                }
                                else
                                {
                                    <button class="btn btn-dark px-5 py-3 text-uppercase">Add to Cart</button>
                                }
                            </div>
                        </div>

                        <div class="sku mt-25">
                            <p class="mb-0">
                                <strong>Availability:</strong>
                                <span class="@Model.StockStatusClass font-weight-bold ml-2">
                                    <i class="fas @(Model.StockStatus == "Out of Stock" ? "fa-times-circle" :
                                                                  (Model.StockStatus.Contains("Limited") ? "fa-exclamation-triangle" : "fa-check-circle")) mr-1"></i>
                                    @Model.StockStatus
                                </span>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="product-view-tab-area mt-80">
    <div class="container-wrapper extra-padding-10 border-b-light-gray pt-60 pb-85">
        <nav class="d-flex justify-content-center">
            <div class="nav review-tabs product-view-tab" id="nav-tab" role="tablist">
                <a class="nav-item nav-link active mr-5" id="nav-home-tab" data-toggle="tab" href="#nav-home" role="tab">Description</a>
                <a class="nav-item nav-link" id="nav-review-tab" data-toggle="tab" href="#nav-review" role="tab">Reviews</a>
            </div>
        </nav>
        <div class="tab-content" id="nav-tabContent">
            <div class="tab-pane fade show active mt-40" id="nav-home" role="tabpanel">
                <div class="describe-area px-5">
                    <h6>Detailed Description</h6>
                    <p class="mt-20">@Model.Description</p>
                </div>
            </div>
            <div class="tab-pane fade mt-40" id="nav-review" role="tabpanel">
                <div class="review-comments area text-center">
                    <h6>Customer Reviews</h6>
                    <p class="text-muted mt-20">There are no reviews for this product yet.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="related-product-area mt-80 mb-100">
    <div class="container-wrapper extra-padding-15">
        <div class="section-title text-center mb-50">
            <h2>#Related products</h2>
            <p class="text-muted">You might also like these products</p>
        </div>
        <div class="row">
            <div class="col-xl-3 col-lg-3 col-md-6 col-sm-6 col-12 mb-30">
                <div class="single-product related-product-card p-3 text-center">
                    <div class="related-img-container">
                        <img src="~/assets/images/product/product1.jpg" alt="Related" class="main-product-img">
                    </div>
                    <div class="mt-3">
                        <div class="small text-muted">Category</div>
                        <h6 class="mt-1"><a href="#" class="text-dark">Related Product 1</a></h6>
                        <span class="theme-color font-weight-bold">$100.00</span>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-lg-3 col-md-6 col-sm-6 col-12 mb-30">
                <div class="single-product related-product-card p-3 text-center">
                    <div class="related-img-container">
                        <img src="~/assets/images/product/product2.jpg" alt="Related" class="main-product-img">
                    </div>
                    <div class="mt-3">
                        <div class="small text-muted">Category</div>
                        <h6 class="mt-1"><a href="#" class="text-dark">Related Product 2</a></h6>
                        <span class="theme-color font-weight-bold">$150.00</span>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-lg-3 col-md-6 col-sm-6 col-12 mb-30">
                <div class="single-product related-product-card p-3 text-center">
                    <div class="related-img-container">
                        <img src="~/assets/images/product/product3.jpg" alt="Related" class="main-product-img">
                    </div>
                    <div class="mt-3">
                        <div class="small text-muted">Category</div>
                        <h6 class="mt-1"><a href="#" class="text-dark">Related Product 3</a></h6>
                        <span class="theme-color font-weight-bold">$200.00</span>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-lg-3 col-md-6 col-sm-6 col-12 mb-30">
                <div class="single-product related-product-card p-3 text-center">
                    <div class="related-img-container">
                        <img src="~/assets/images/product/product4.jpg" alt="Related" class="main-product-img">
                    </div>
                    <div class="mt-3">
                        <div class="small text-muted">Category</div>
                        <h6 class="mt-1"><a href="#" class="text-dark">Related Product 4</a></h6>
                        <span class="theme-color font-weight-bold">$250.00</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('scrollUp')?.addEventListener('click', function() {
        document.querySelector('.p-tap-vertical').scrollTop -= 110;
    });

    document.getElementById('scrollDown')?.addEventListener('click', function() {
        document.querySelector('.p-tap-vertical').scrollTop += 110;
    });
</script>
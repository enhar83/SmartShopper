@model List<Core_Layer.Dtos.OrderDtos.OrderListDto>
@{
    ViewData["Title"] = "My Orders";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="contact-area bg-light pt-80 pb-100">
    <div class="container-wrapper extra-padding-15">
        <div class="row">
            <div class="col-xl-4 col-lg-4 col-md-12">
                <div class="contact-form-left text-center rounded bg-white shadow-sm p-5 border">
                    <div class="nav flex-column nav-pills custom-dashboard-tabs">
                        <a class="nav-link mb-2" asp-controller="Profile" asp-action="ViewProfile"><i class="fas fa-user-circle mr-10"></i>My Profile</a>
                        <a class="nav-link active mb-2" asp-controller="Order" asp-action="Index"><i class="fas fa-shopping-bag mr-10"></i>My Orders</a>
                    </div>
                    <div class="bottom-line mt-30 mb-20"></div>
                    <p class="text-muted small ls-1 text-uppercase font-weight-bold">Dashboard</p>
                </div>
            </div>

            <div class="col-xl-8 col-lg-8 col-md-12 mt-md-30">
                <div class="bg-white rounded shadow-sm border p-5" style="min-height: 550px;">
                    <div class="d-flex justify-content-between align-items-center mb-40 border-bottom pb-3">
                        <h3 class="mb-0 font-weight-bold text-dark">Order History</h3>
                    </div>

                    @if (Model != null && Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle" style="min-width: 600px;">
                                <thead>
                                    <tr class="small text-uppercase ls-1 font-weight-bold text-muted border-bottom">
                                        <th class="py-3 text-left" style="width: 25%;">Date</th>
                                        <th class="py-3 text-left" style="width: 25%;">Total</th>
                                        <th class="py-3 text-center" style="width: 25%;">Status</th>
                                        <th class="py-3 text-right" style="width: 25%;">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model)
                                    {
                                        <tr class="order-row border-bottom">
                                            <td class="text-left text-muted">@order.CreatedDate.ToString("dd MMM yyyy")</td>
                                            <td class="text-left font-weight-bold text-dark">@order.TotalPrice.ToString("C")</td>
                                            <td class="text-center">
                                                <span class="badge badge-dark px-3 py-2 text-uppercase" style="font-size: 10px; letter-spacing: 1px; min-width: 80px;">@order.StatusDescription</span>
                                            </td>
                                            <td class="text-right">
                                                <button class="btn btn-dark btn-sm rounded-0 px-4 btn-order-detail text-uppercase font-weight-bold" style="font-size: 11px;" data-id="@order.Id">
                                                    DETAILS
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-box-open fa-3x text-light mb-3"></i>
                            <p class="text-muted">You don't have any orders yet.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="orderDetailModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow-lg rounded-0">
            <div class="modal-header bg-dark text-white rounded-0">
                <h5 class="modal-title text-white font-weight-bold text-uppercase ls-1" style="font-size: 16px;"><i class="fas fa-receipt mr-2"></i>ORDER SUMMARY</h5>
                <button type="button" class="close text-white outline-none" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body p-5 text-left" id="modalOrderContent"></div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .custom-dashboard-tabs .nav-link {
            color: #666;
            border: 1px solid #f0f0f0;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: 0.2s;
        }

            .custom-dashboard-tabs .nav-link.active {
                background-color: #222 !important;
                border-color: #222;
                color: #fff !important;
            }

            .custom-dashboard-tabs .nav-link:hover:not(.active) {
                color: #000;
                border-color: #222;
            }

        .ls-1 {
            letter-spacing: 1px;
        }

        .border-light {
            border: 1px solid #eee !important;
        }

        .btn-dark {
            background-color: #222 !important;
            border: none;
        }

        .outline-none {
            outline: none !important;
            box-shadow: none !important;
        }

        .order-row:hover {
            background-color: #fcfcfc;
        }

        .img-placeholder {
            width: 60px;
            height: 60px;
            background-color: #f8f9fa;
            border: 1px solid #eee;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #ccc;
            font-size: 20px;
        }

        .product-thumbnail {
            width: 60px;
            height: 60px;
            object-fit: cover;
            background-color: #fff;
        }

        .table th, .table td {
            vertical-align: middle !important;
        }
    </style>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            window.handleImgError = function(img) {
                img.onerror = null;
                const parent = img.parentElement;
                parent.innerHTML = '<div class="img-placeholder rounded shadow-sm"><i class="fas fa-image"></i></div>';
            };

            $(".btn-order-detail").on('click', function () {
                const orderId = $(this).data("id");
                $("#modalOrderContent").html('<div class="text-center p-5"><div class="spinner-border text-dark"></div></div>');
                $("#orderDetailModal").modal("show");

                $.get('/Order/Details/' + orderId)
                    .done(function (data) {
                        const items = data.orderItems || data.OrderItems;
                        if (!items) return;

                        let itemsHtml = '';
                        items.forEach(item => {
                            const rawImg = item.productImageUrl || item.ProductImageUrl;
                            let imgCell = '';

                            if (rawImg === "NO_IMAGE" || !rawImg) {
                                imgCell = '<div class="img-placeholder rounded shadow-sm"><i class="fas fa-image"></i></div>';
                            } else {
                                imgCell = `<img src="${rawImg}" class="product-thumbnail border shadow-sm rounded" onerror="handleImgError(this)">`;
                            }

                            itemsHtml += `
                                <tr class="border-bottom">
                                    <td class="py-3 text-left" style="width: 80px;">${imgCell}</td>
                                    <td class="py-3 text-left font-weight-bold text-dark">${item.productName || item.ProductName}</td>
                                    <td class="py-3 text-center text-muted">${item.quantity}</td>
                                    <td class="py-3 text-right text-dark font-weight-bold">
                                        ${new Intl.NumberFormat('tr-TR', { style: 'currency', currency: 'TRY' }).format(item.priceAtPurchase)}
                                    </td>
                                </tr>`;
                        });

                        $("#modalOrderContent").html(`
                            <div class="row mb-4 border-bottom pb-4">
                                <div class="col-md-5 border-right">
                                    <label class="small text-muted text-uppercase d-block ls-1 font-weight-bold">Reference</label>
                                    <span class="font-weight-bold text-dark text-uppercase small">${data.id.substring(0, 8)}</span>
                                </div>
                                <div class="col-md-7 text-md-right">
                                    <label class="small text-muted text-uppercase d-block ls-1 font-weight-bold">Shipping Address</label>
                                    <span class="small font-weight-bold d-block text-muted text-uppercase">${data.deliveryAddressSnapshot}</span>
                                </div>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-borderless align-middle">
                                    <thead>
                                        <tr class="small text-uppercase text-muted ls-1 border-bottom">
                                            <th class="text-left">Image</th>
                                            <th class="text-left">Product</th>
                                            <th class="text-center">Qty</th>
                                            <th class="text-right">Price</th>
                                        </tr>
                                    </thead>
                                    <tbody>${itemsHtml}</tbody>
                                </table>
                            </div>
                            <div class="text-right mt-4 pt-4 border-top">
                                <p class="text-muted small text-uppercase mb-1 font-weight-bold">GRAND TOTAL</p>
                                <h3 class="font-weight-bold text-dark">${new Intl.NumberFormat('tr-TR', { style: 'currency', currency: 'TRY' }).format(data.totalPrice)}</h3>
                            </div>
                        `);
                    });
            });
        });
    </script>
}
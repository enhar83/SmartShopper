@using Core_Layer.Dtos.RecommendationDtos
@model List<RecommendedProductDto>

@{
    ViewData["Title"] = "Matching Your Wishlist";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var tokens = Antiforgery.GetAndStoreTokens(Context);
}

<style>
    /* Ortak Stiller Ana Şablonla Aynı */
    .single-product {
        border: 1px solid #f0f0f0;
        border-radius: 12px;
        background: #fff;
        height: 100%;
        overflow: hidden;
        position: relative;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        display: flex;
        flex-direction: column;
    }

        .single-product:hover {
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            transform: translateY(-8px);
        }
    /* Turuncu Badge */
    .ai-score-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        z-index: 10;
        background: linear-gradient(135deg, #e67e22 0%, #d35400 100%);
        color: #fff;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .product-img-container {
        height: 260px;
        position: relative;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        padding: 20px;
    }

        .product-img-container img {
            transition: transform 0.5s ease;
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }

    .single-product:hover .product-img-container img {
        transform: scale(1.08);
    }

    .recommendation-reason-badge {
        position: absolute;
        bottom: 10px;
        left: 15px;
        padding: 4px 10px;
        font-size: 10px;
        font-weight: 600;
        color: #444;
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(4px);
        border: 1px solid #eee;
        border-radius: 4px;
        z-index: 3;
    }

    .product-info-padding {
        padding: 20px;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        border-top: 1px solid #f9f9f9;
    }

    .product-title {
        font-size: 15px;
        font-weight: 600;
        margin-bottom: 8px;
        display: block;
        color: #333;
        text-decoration: none;
        height: 40px;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        text-transform: capitalize;
    }
    /* Turuncu Text */
    .match-text {
        font-size: 12px;
        color: #e67e22;
        font-weight: 700;
        margin-bottom: 10px;
        letter-spacing: 0.5px;
    }

    .price-container {
        position: relative;
        height: 35px;
        overflow: hidden;
        margin-top: auto;
    }

    .product-price {
        font-size: 18px;
        color: #222;
        font-weight: 700;
        transition: transform 0.3s ease;
        display: block;
        line-height: 35px;
    }
    /* Turuncu Buton */
    .add-to-cart-btn {
        position: absolute;
        top: 35px;
        left: 0;
        font-size: 12px;
        font-weight: 700;
        color: #e67e22;
        text-transform: uppercase;
        text-decoration: none;
        transition: transform 0.3s ease;
        display: flex;
        align-items: center;
        line-height: 35px;
        cursor: pointer;
        border: none;
        background: transparent;
        padding: 0;
    }

    .single-product:hover .product-price {
        transform: translateY(-35px);
    }

    .single-product:hover .add-to-cart-btn {
        transform: translateY(-35px);
    }

    .theme-color {
        color: #e67e22 !important;
    }

    .ai-header-section {
        background: #fffcf8;
        padding: 60px 0;
        border-bottom: 1px solid #fdebd0;
    }
</style>

<div class="ai-header-section">
    <div class="container text-center">
        <div class="mb-3">
            <span class="badge px-3 py-2 rounded-pill" style="background:#fdebd0; color:#e67e22;">
                <i class="fas fa-heart mr-2"></i> WISHLIST INSIGHTS ACTIVE
            </span>
        </div>
        <h2 class="mb-2 text-dark font-weight-bold">Matching Your Wishlist</h2>
        <p class="text-muted mx-auto" style="max-width: 600px;">We explored the items you've saved to find other products that reflect your unique style and taste.</p>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb justify-content-center bg-transparent p-0 mt-3">
                <li class="breadcrumb-item"><a href="/" class="theme-color font-weight-bold">Home</a></li>
                <li class="breadcrumb-item active">Wishlist AI</li>
            </ol>
        </nav>
    </div>
</div>

<div class="recommendation-main-area mt-50 pb-80">
    <div class="container">
        <div class="shop-header-area mb-40 d-flex justify-content-between align-items-center border-bottom pb-3">
            <h6 class="text-muted font-weight-bold ls-1 text-uppercase small">AI-Powered Predictions</h6>
            <div class="ai-status">
                <small class="text-success"><i class="fas fa-check-circle"></i> Engine Online</small>
            </div>
        </div>

        <div id="recommendation-list" class="row">
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <div class="col-xl-3 col-md-4 col-sm-6 mb-4">
                        <div class="single-product shadow-sm">
                            <div class="ai-score-badge">
                                <i class="fas fa-magic"></i> %@item.MatchPercentage Fit
                            </div>
                            <div class="product-img-container">
                                <div class="recommendation-reason-badge">
                                    <i class="far fa-star mr-1"></i> @item.RecommendationReason
                                </div>
                                <a href="/Product/ProductDetails/@item.ProductId" class="w-100 h-100 d-flex align-items-center justify-content-center">
                                    @if (!string.IsNullOrEmpty(item.MainImageUrl) && item.MainImageUrl != "NO_IMAGE")
                                    {
                                        <img src="@item.MainImageUrl" alt="@item.ProductName">
                                    }
                                    else
                                    {

                                        <i class="fas fa-image fa-4x text-light"></i>
                                    }
                                </a>
                            </div>
                            <div class="product-info-padding">
                                <div class="match-text text-uppercase">Style Match</div>
                                <a href="/Product/ProductDetails/@item.ProductId" class="product-title">@item.ProductName</a>
                                <div class="price-container">
                                    <span class="product-price">$@item.Price.ToString("N2")</span>
                                    <button class="add-to-cart-btn font-weight-bold" onclick="addToCart('@item.ProductId')">
                                        <i class="fas fa-shopping-basket mr-1"></i> ADD TO CART
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <div class="mb-4"><i class="far fa-heart fa-4x text-muted opacity-25"></i></div>
                    <h4 class="text-dark">Wishlist is Too Empty</h4>
                    <p class="text-muted">Add at least 3 items to your wishlist so our AI can learn your style.</p>
                    <a href="/Product/ProductList" class="btn btn-dark mt-3 rounded-pill px-5 font-weight-bold">Explore Products</a>
                </div>
            }
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    const Toast = Swal.mixin({
        toast: true,
        position: 'top-end',
        showConfirmButton: false,
        timer: 3000,
        timerProgressBar: true
    });

    async function addToCart(productId) {
        const token = '@tokens.RequestToken';
        try {
            const response = await fetch('/Cart/AddToCart', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token,
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({ ProductId: productId, Quantity: 1 })
            });

            const result = await response.json();

            if (response.ok && result.success) {
                Toast.fire({
                    icon: 'success',
                    title: 'Added to your cart!'
                });
                if (typeof refreshMiniCart === "function") refreshMiniCart();
            } else {
                Toast.fire({
                    icon: 'warning',
                    title: result.message || 'Could not add to cart.'
                });
            }
        } catch (error) {
            Toast.fire({
                icon: 'error',
                title: 'A technical error occurred!'
            });
        }
    }
</script>
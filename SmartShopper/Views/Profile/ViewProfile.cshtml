@using Core_Layer.Dtos.ProfileDtos
@model ViewProfileDto

@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Shared/_Layout.cshtml";

    string initials = "";
    if (!string.IsNullOrEmpty(Model.Name)) initials += Model.Name[0];
    if (!string.IsNullOrEmpty(Model.Surname)) initials += Model.Surname[0];
    initials = initials.ToUpper();
}

<div class="contact-area bg-light pt-50">
    <div class="container-wrapper extra-padding-15">
        <div class="row pb-100">
            <div class="col-xl-4 col-lg-5 col-md-12">
                <div class="contact-form-left mt-60 text-center rounded bg-white shadow-sm p-5 border">
                    <div class="section-title text-center">
                        <div class="profile-avatar-container mb-30 d-flex justify-content-center">
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <img src="@Model.ImageUrl" alt="Profile" class="rounded-circle shadow" style="width: 150px; height: 150px; object-fit: cover; border: 5px solid #fff;">
                            }
                            else
                            {
                                <div class="rounded-circle shadow d-flex align-items-center justify-content-center text-white fw-bold"
                                     style="width: 150px; height: 150px; background: linear-gradient(135deg, #FF5722 0%, #FF9800 100%); font-size: 64px; border: 5px solid #fff;">
                                    @initials
                                </div>
                            }
                        </div>
                        <h3 class="mb-10">@Model.Name @Model.Surname</h3>
                        <p class="theme-color mb-30">@@@Model.UserName</p>
                        <div class="bottom-line mb-30"></div>
                        <p class="text-muted small">Your profile information is securely stored.</p>
                    </div>
                </div>
            </div>

            <div class="col-xl-8 col-lg-7 col-md-12">
                <div class="contact-form-right mt-60 rounded bg-white shadow-sm p-5 border">
                    <div class="d-flex justify-content-between align-items-center mb-35">
                        <h3 class="mb-0">Account Details</h3>
                        <div class="d-flex gap-2">
                            <button type="button" id="btnManageAddresses" class="btn btn-outline-dark transition text-uppercase btn-sm mr-2" style="padding: 10px 20px; font-size: 12px; font-weight: 600;">
                                <i class="fas fa-map-marked-alt mr-2"></i>My Addresses
                            </button>
                            <button type="button" id="btnEditProfile" class="review-btn d-inline-block text-white theme-bg transition text-uppercase btn-sm border-0" style="padding: 10px 20px; font-size: 12px; cursor:pointer;">
                                <i class="fas fa-user-edit mr-10"></i>Edit Profile
                            </button>
                        </div>
                    </div>

                    <div class="contact-form profile-view-form">
                        <div class="row">
                            <div class="col-md-6 mb-25">
                                <label class="fw-bold text-dark text-uppercase">First Name</label>
                                <div class="p-3 border rounded bg-light text-muted">@Model.Name</div>
                            </div>
                            <div class="col-md-6 mb-25">
                                <label class="fw-bold text-dark text-uppercase">Last Name</label>
                                <div class="p-3 border rounded bg-light text-muted">@Model.Surname</div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-25">
                                <label class="fw-bold text-dark text-uppercase">Email Address</label>
                                <div class="p-3 border rounded bg-light text-muted">@Model.Email</div>
                            </div>
                            <div class="col-md-6 mb-25">
                                <label class="fw-bold text-dark text-uppercase">Phone Number</label>
                                <div class="p-3 border rounded bg-light text-muted">@(Model.PhoneNumber ?? "Not Provided")</div>
                            </div>
                        </div>
                        <div class="row justify-content-center">
                            <div class="col-md-6 mb-25 text-center">
                                <label class="fw-bold text-dark text-uppercase">Username</label>
                                <div class="p-3 border rounded bg-light text-muted">@Model.UserName</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header theme-bg text-white">
                <h5 class="modal-title text-white"><i class="fas fa-user-cog mr-2"></i> Update Profile Details</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form id="editProfileForm" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editId" name="Id" />
                <div class="modal-body p-4">
                    <div id="errorList" class="alert alert-danger d-none"></div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="small text-uppercase fw-bold">First Name</label>
                            <input type="text" id="editName" name="Name" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="small text-uppercase fw-bold">Last Name</label>
                            <input type="text" id="editSurname" name="Surname" class="form-control" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="small text-uppercase fw-bold">Username</label>
                            <input type="text" id="editUserName" name="UserName" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="small text-uppercase fw-bold">Phone Number</label>
                            <input type="text" id="editPhone" name="PhoneNumber" class="form-control" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="small text-uppercase fw-bold">Profile Picture</label>
                        <div class="d-flex align-items-center mt-2">
                            <img id="currentImagePreview" src="" class="rounded-circle mr-3 shadow-sm" style="width: 60px; height: 60px; object-fit: cover; display:none; border: 2px solid #eee;">
                            <input type="file" name="UserImage" class="form-control-file" id="userImageInput" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light justify-content-end">
                    <button type="button" class="btn btn-secondary btn-fixed-size" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="review-btn text-white theme-bg border-0 btn-fixed-size ml-2">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="addressListModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title text-white"><i class="fas fa-map-marker-alt mr-2"></i> My Registered Addresses</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body p-0">
                <div id="addressContainer" class="p-4" style="max-height: 400px; overflow-y: auto;">
                    <div class="text-center p-5">
                        <div class="spinner-border theme-color" role="status"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary btn-fixed-size" data-dismiss="modal">Close</button>
                <button type="button" id="btnOpenAddAddress" class="review-btn text-white theme-bg border-0 btn-fixed-size ml-2">Add New</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addAddressModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header theme-bg text-white">
                <h5 class="modal-title text-white"><i class="fas fa-plus mr-2"></i> Add New Address</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form id="addAddressForm">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <div id="addAddressErrorList" class="alert alert-danger d-none"></div>
                    <div class="mb-3">
                        <label class="small text-uppercase fw-bold">Address Title</label>
                        <input type="text" name="Title" class="form-control" placeholder="Home, Office etc." required />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="small text-uppercase fw-bold">Country</label>
                            <input type="text" name="Country" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="small text-uppercase fw-bold">City</label>
                            <input type="text" name="City" class="form-control" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="small text-uppercase fw-bold">District</label>
                        <input type="text" name="District" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="small text-uppercase fw-bold">Full Address</label>
                        <textarea name="FullAddress" class="form-control" rows="3" required></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary btn-fixed-size" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="review-btn text-white theme-bg border-0 btn-fixed-size ml-2">Save Address</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .profile-view-form label {
            margin-bottom: 8px;
            font-size: 13px;
            letter-spacing: 0.5px;
            color: #777;
        }

        .profile-view-form .bg-light {
            background-color: #fcfcfc !important;
            border-color: #f0f0f0 !important;
            min-height: 50px;
            display: flex;
            align-items: center;
        }

        .theme-color {
            color: #FF5722 !important;
        }

        .theme-bg {
            background-color: #FF5722 !important;
        }

        .modal-header.theme-bg {
            border-bottom: 0;
        }

        .form-control:focus {
            border-color: #FF5722;
            box-shadow: none;
        }

        .btn-fixed-size {
            min-width: 140px;
            height: 45px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 4px;
            font-size: 13px;
            font-weight: 600;
            text-transform: uppercase;
            transition: all 0.3s;
        }

        .address-card {
            border-left: 4px solid #FF5722;
            transition: transform 0.2s;
        }

            .address-card:hover {
                transform: translateX(5px);
                background-color: #f9f9f9;
            }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            $('#btnEditProfile').on('click', function () {
                $.ajax({
                    url: '/Profile/GetProfileForEdit',
                    type: 'GET',
                    success: function (res) {
                        $('#editId').val(res.id);
                        $('#editName').val(res.name);
                        $('#editSurname').val(res.surname);
                        $('#editUserName').val(res.userName);
                        $('#editPhone').val(res.phoneNumber);
                        if (res.userImage) { $('#currentImagePreview').attr('src', res.userImage).show(); }
                        else { $('#currentImagePreview').hide(); }
                        $('#errorList').addClass('d-none').empty();
                        $('#editModal').modal('show');
                    }
                });
            });

            $('#btnManageAddresses').on('click', function () {
                $('#addressListModal').modal('show');
                loadAddresses();
            });

            $('#btnOpenAddAddress').on('click', function () {
                $('#addAddressErrorList').addClass('d-none').empty();
                $('#addAddressForm')[0].reset();
                $('#addAddressModal').modal('show');
            });

            function loadAddresses() {
                $('#addressContainer').html('<div class="text-center p-5"><div class="spinner-border theme-color" role="status"></div></div>');
                $.ajax({
                    url: '/UserAddress/UserAddressList',
                    type: 'GET',
                    success: function (res) {
                        let html = '';
                        if (res.succeeded && res.data.length > 0) {
                            res.data.forEach(addr => {
                                html += `
                                    <div class="address-card p-3 mb-3 border rounded bg-white shadow-sm">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <h6 class="fw-bold mb-1 text-uppercase">${addr.title}</h6>
                                                <p class="small text-muted mb-0">${addr.fullAddress}</p>
                                                <p class="small text-dark mb-0 font-italic">${addr.city} / ${addr.country}</p>
                                            </div>
                                            <div class="btn-group">
                                                <button class="btn btn-sm btn-outline-primary border-0"><i class="fas fa-edit"></i></button>
                                                <button class="btn btn-sm btn-outline-danger border-0"><i class="fas fa-trash-alt"></i></button>
                                            </div>
                                        </div>
                                    </div>`;
                            });
                        } else {
                            html = '<div class="text-center p-5 text-muted"><i class="fas fa-map-marked fa-3x mb-3"></i><p>No registered addresses found.</p></div>';
                        }
                        $('#addressContainer').html(html);
                    }
                });
            }

            $('#addAddressForm').on('submit', function (e) {
                e.preventDefault();
                let formData = $(this).serialize();
                $.ajax({
                    url: '/UserAddress/AddAddress',
                    type: 'POST',
                    data: formData,
                    success: function (res) {
                        if (res.succeeded) {
                            $('#addAddressModal').modal('hide');
                            Swal.fire({ icon: 'success', title: 'Success', text: res.message, timer: 1500, showConfirmButton: false });
                            loadAddresses();
                        }
                    },
                    error: function (xhr) {
                        let res = xhr.responseJSON;
                        let errorHtml = '<ul class="mb-0">';
                        if (res && res.errors) { $.each(res.errors, function (i, item) { errorHtml += '<li>' + item + '</li>'; }); }
                        else { errorHtml += '<li>Unexpected server error.</li>'; }
                        errorHtml += '</ul>';
                        $('#addAddressErrorList').html(errorHtml).removeClass('d-none');
                    }
                });
            });

            $('#editProfileForm').on('submit', function (e) {
                e.preventDefault();
                let formData = new FormData(this);
                $.ajax({
                    url: '/Profile/EditProfile',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function (res) {
                        if (res.succeeded) {
                            $('#editModal').modal('hide');
                            Swal.fire({ icon: 'success', title: 'Updated', timer: 1500, showConfirmButton: false }).then(() => location.reload());
                        }
                    },
                    error: function (xhr) {
                        let res = xhr.responseJSON;
                        let errorHtml = '<ul class="mb-0">';
                        if (res && res.errors) { $.each(res.errors, function (i, item) { errorHtml += '<li>' + item + '</li>'; }); }
                        else { errorHtml += '<li>Unexpected server error.</li>'; }
                        errorHtml += '</ul>';
                        $('#errorList').html(errorHtml).removeClass('d-none');
                    }
                });
            });
        });
    </script>
}
<!doctype html>
<html class="no-js" lang="zxx">
<head>
	<meta charset="utf-8">
	<meta http-equiv="x-ua-compatible" content="ie=edge">
	<title>SmartShopper</title>
	<meta name="description" content="">
	<meta name="viewport" content="width=device-width, initial-scale=1">

	<link rel="shortcut icon" href="~/assets/images/logo/favicons.png" type="image/x-icon">

	<link rel="stylesheet" href="~/assets/css/bootstrap.min.css">
	<link rel="stylesheet" href="~/assets/css/fontawesome-all.min.css">
	<link rel="stylesheet" href="~/assets/css/animate.css">
	<link rel="stylesheet" href="~/assets/css/meanmenu.css">
	<link rel="stylesheet" href="~/assets/css/audioplayer.css">
	<link rel="stylesheet" href="~/assets/css/jquery.fancybox.min.css">
	<link rel="stylesheet" href="~/assets/css/flaticon.css">
	<link rel="stylesheet" href="~/assets/css/slick.css">
	<link rel="stylesheet" href="~/assets/css/icomoon.css">
	<link rel="stylesheet" href="~/assets/css/default.css">
	<link rel="stylesheet" href="~/assets/css/style.css">
	<link rel="stylesheet" href="~/assets/css/responsive.css">

	<style>
		/* Temanın gereksiz yerlere otomatik ok atmasını engellemek için */
		.main-menu nav > ul > li.no-arrow > a::after,
		.main-menu nav > ul > li.no-arrow > a::before {
			display: none !important;
			content: "" !important;
		}
	</style>
</head>
<body>

	<header>
		<div id="header-sticky" class="header-area">
			<div class="header pl-30 pr-30 pt-15 pb-15">
				<div class="container-fluid">
					<div class="row align-items-center justify-content-lg-between position-relative">

						<div class="col-xl-5 col-lg-5 col-md-4 col-sm-4 col-4 pr-0 d-lg-flex align-items-lg-center position-static">
							<div class="d-block d-lg-none">
								<a class="mobile-menubar" href="javascript:void(0);"><span class="icon-menu"></span></a>
							</div>

							<div class="main-menu">
								<nav id="mobile-menu">
									<ul class="d-block">

										<li class="no-arrow"><a href="/Home/Index">Home</a></li>

										<li class="no-arrow"><a href="/Product/ProductList">Shop</a></li>

										<li>
											<a href="javascript:void(0);">Smart Suggestions</a>
											<ul class="mega-menu pt-20 pb-20 pl-20 pr-20 border-gray bg-white shadow-sm" style="min-width: 280px; border-radius: 5px;">
												<li class="mb-3">
													<a href="/Recommendation/GetOrderRecommendations" class="d-flex align-items-center">
														<i class="fas fa-shopping-cart text-primary mr-3" style="font-size: 18px;"></i>
														<span>Order Recommendations</span>
													</a>
												</li>
												<li class="mb-3">
													<a href="/Recommendation/GetFavoriteRecommendations" class="d-flex align-items-center">
														<i class="fas fa-heart text-danger mr-3" style="font-size: 18px;"></i>
														<span>Favorite Recommendations</span>
													</a>
												</li>
												<li>
													<a href="/Recommendation/GetCartRecommendations" class="d-flex align-items-center">
														<i class="fas fa-shopping-cart text-warning mr-3" style="font-size: 18px;"></i>
														<span>Cart Recommendations</span>
													</a>
												</li>
											</ul>
										</li>

										<li>
											<a href="javascript:void(0);">My Account</a>
											<ul class="mega-menu pt-20 pb-20 pl-20 pr-20 border-gray bg-white shadow-sm" style="min-width: 220px; border-radius: 5px;">
												<li class="mb-3">
													<a href="/Profile/ViewProfile" class="d-flex align-items-center">
														<i class="fas fa-user-circle text-info mr-3" style="font-size: 18px;"></i>
														<span>My Profile</span>
													</a>
												</li>
												<li class="mb-3">
													<a href="/Order/Index" class="d-flex align-items-center">
														<i class="fas fa-truck text-success mr-3" style="font-size: 18px;"></i>
														<span>My Orders</span>
													</a>
												</li>
												<li class="mb-3">
													<a href="/Favorite/Index" class="d-flex align-items-center">
														<i class="fas fa-star text-danger mr-3" style="font-size: 18px;"></i>
														<span>Wishlist</span>
													</a>
												</li>
												<li>
													<a href="/Cart/Index" class="d-flex align-items-center">
														<i class="fas fa-shopping-basket text-warning mr-3" style="font-size: 18px;"></i>
														<span>Shopping Cart</span>
													</a>
												</li>
												<li>
													<a href="/Comment/Index" class="d-flex align-items-center">
														<i class="fas fa-comments text-success mr-3" style="font-size: 18px;"></i>
														<span>My Comments</span>
													</a>
												</li>
												<li>
													<a href="/Discount/Index" class="d-flex align-items-center">
														<i class="fas fa-tags text-info mr-3" style="font-size: 18px;"></i>
														<span>My Discounts</span>
													</a>
												</li>
											</ul>
										</li>

									</ul>
								</nav>
							</div>
						</div>

						<div class="col-xl-2 col-lg-2 col-md-4 col-sm-4 col-4 d-flex align-items-center justify-content-center">
							<div class="logo">
								<a href="/" class="d-block"><img src="~/assets/images/logo/logo.png" alt="HOMESS"></a>
							</div>
						</div>

						<div class="col-xl-5 col-lg-5 col-md-4 col-sm-4 col-4">
							<div class="header-right d-flex justify-content-end align-items-center">

								<ul class="header-login d-none d-lg-block">
									@if (Context.Request.Cookies.ContainsKey("JwtToken"))
									{
										<li>
											<a href="/Account/Logout" class="text-danger">
												<span class="icon-users"></span>
												<span class="logo-register ml-2 font-weight-bold">Logout</span>
											</a>
										</li>
									}
									else
									{
										<li>
											<a href="/Account/Login">
												<span class="icon-users"></span>
												<span class="logo-register ml-2">Login / Register</span>
											</a>
										</li>
									}
								</ul>

								<ul class="header-search d-none d-lg-block">
									<li><span class="icon-search"></span></li>
								</ul>

								<ul class="header-heart d-none d-lg-block">
									<li><a href="/Favorite/Index"><span class="icon-heart"></span></a></li>
								</ul>

								<ul class="d-none d-lg-block">
									<li class="position-relative" id="miniNotificationContainer" style="margin-right: 15px;">
										@await Component.InvokeAsync("_NavbarNotificationListComponentPartial")
									</li>
								</ul>

								<ul>
									<li class="position-relative" id="miniCartContainer">
										@await Component.InvokeAsync("_CartNavbarComponentPartial")
									</li>
								</ul>

							</div>
						</div>

					</div>
				</div>
			</div>
		</div>
	</header>

	<main>
		@RenderBody()
	</main>

	<footer>
		<div class="footer-area-area theme-bg">
			<div class="footer-top pt-100 pb-100">
				<div class="container-wrapper extra-padding-15">
					<div class="row justify-content-center align-items-center">
						<div class="col-xl-12 col-lg-12 col-md-12 col-sm-12 col-12">
							<div class="footer-top-content text-center">
								<div class="footer-logo mb-35">
									<a href="/"><img src="~/assets/images/logo/logo.png" alt=""></a>
								</div>
								<p>SmartShopper is an advanced e-commerce platform.</p>
							</div>
						</div>
					</div>
				</div>
			</div>
			<div class="footer-bottom">
				<div class="container-wrapper extra-padding-15">
					<div class="copyright-area pt-45 pb-25">
						<div class="row align-items-center justify-content-center">
							<div class="col-xl-12 col-lg-12 col-md-12 col-sm-12 col-12 text-center">
								<p>Copyright © <a href="#">SmartShopper</a> All Rights Reserved.</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</footer>

	<div class="scroll-up" id="scroll">
		<a href="#"><span class="icon-chevrons-up"></span></a>
	</div>

	<script src="~/assets/js/vendor/modernizr-3.5.0.min.js"></script>
	<script src="~/assets/js/vendor/jquery-1.12.4.min.js"></script>
	<script src="~/assets/js/popper.min.js"></script>
	<script src="~/assets/js/bootstrap.min.js"></script>
	<script src="~/assets/js/jquery.inputarrow.js"></script>
	<script src="~/assets/js/jquery.fancybox.min.js"></script>
	<script src="~/assets/js/isotope.pkgd.min.js"></script>
	<script src="~/assets/js/plugins.js"></script>
	<script src="~/assets/js/wow.min.js"></script>
	<script src="~/assets/js/audioplayer.js"></script>
	<script src="~/assets/js/main.js"></script>
	<script src="~/assets/js/slick.min.js"></script>
	<script src="~/assets/js/jquery.meanmenu.min.js"></script>

	<script>
		function refreshMiniCart() {
			$.get('/Cart/GetMiniCartComponent', function (data) {
				$('#miniCartContainer').html(data);
			});
		}
	</script>

	@await RenderSectionAsync("Scripts", required: false)
	@await RenderSectionAsync("Styles", required: false)

</body>
</html>
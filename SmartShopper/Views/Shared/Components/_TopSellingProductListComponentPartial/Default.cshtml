@model List<Core_Layer.Dtos.ProductDtos.TopSellingProductListDto>

@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var tokens = Antiforgery.GetAndStoreTokens(Context);
}

<style>
    .best-seller-card {
        border: 1px solid #f0f0f0;
        border-radius: 12px;
        background: #fff;
        height: 100%;
        overflow: hidden;
        position: relative;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        display: flex;
        flex-direction: column;
        margin-bottom: 30px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.02);
    }

        .best-seller-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            border-color: #e67e22;
        }

        .best-seller-card .fav-button {
            position: absolute;
            top: 60px;
            right: 15px;
            z-index: 10;
            background: rgba(255, 255, 255, 0.9);
            border: none;
            border-radius: 50%;
            width: 38px;
            height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            cursor: pointer;
            transition: 0.3s;
        }

            .best-seller-card .fav-button:hover {
                background: #fff;
                transform: scale(1.15);
            }

    .fav-button .fas.fa-heart {
        color: #e74c3c;
    }
    .fav-button .far.fa-heart {
        color: #aaa;
    }

    .bs-img-container {
        height: 280px;
        position: relative;
        background: #f9f9f9;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

        .bs-img-container img {
            transition: transform 0.6s ease;
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .best-seller-card:hover .bs-img-container img {
        transform: scale(1.08);
    }

    .no-image-placeholder {
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: #aab2bd;
    }

    .bs-label {
        position: absolute;
        top: 15px;
        left: 15px;
        padding: 5px 14px;
        font-size: 11px;
        font-weight: 800;
        color: #fff;
        border-radius: 6px;
        z-index: 3;
        background: #d4a373;
        letter-spacing: 0.5px;
    }

    .bs-info {
        padding: 20px;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }

    .bs-category-info {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 8px;
        font-weight: 600;
        color: #95a5a6;
    }

    .bs-sales-tag {
        font-size: 13px;
        color: #e67e22;
        font-weight: 700;
        margin-bottom: 6px;
    }

    .bs-title {
        font-size: 16px;
        font-weight: 600;
        margin-bottom: 15px;
        display: block;
        color: #2c3e50;
        text-decoration: none;
        height: 44px;
        overflow: hidden;
        line-height: 1.4;
    }

    .bs-price {
        font-size: 20px;
        color: #222;
        font-weight: 800;
        margin-top: auto;
    }
</style>

<div class="product-area pt-75 pb-50">
    <div class="container">
        <div class="row">
            <div class="col-xl-6 col-lg-6 col-md-10 col-sm-12 col-12 offset-xl-3 offset-lg-3 offset-md-1 text-center">
                <div class="section-title">
                    <h2 class="pb-20">#Best Sellers</h2>
                    <p class="text-muted">Explore our top-performing products that customers love the most.</p>
                </div>
            </div>
        </div>

        <div class="product-content mt-40">
            <div class="row">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <div class="col-xl-3 col-lg-4 col-md-6 col-sm-6">
                            <div class="best-seller-card wow fadeInUp animated">

                                <button class="fav-button" onclick="handleFavoriteBS('@item.Id', this)" title="Add to Wishlist">
                                    <i class="@(item.IsFavorite ? "fas fa-heart" : "far fa-heart")"></i>
                                </button>

                                <div class="bs-img-container">
                                    <div class="bs-label">HOT</div>

                                    <a href="/Product/ProductDetail/@item.Id" class="w-100 h-100">
                                        @if (!string.IsNullOrEmpty(item.MainImageUrl) && item.MainImageUrl != "NO_IMAGE")
                                        {
                                            <img src="@item.MainImageUrl" alt="@item.Name">
                                        }
                                        else
                                        {
                                            <div class="no-image-placeholder">
                                                <i class="fas fa-image fa-3x"></i>
                                                <span>No Image</span>
                                            </div>
                                        }
                                    </a>
                                </div>

                                <div class="bs-info">
                                    <div class="bs-sales-tag"><i class="fas fa-fire mr-1"></i> @item.TotalSalesCount Sales</div>

                                    <div class="bs-category-info">
                                        <span>@item.CategoryName</span>
                                        @if (!string.IsNullOrEmpty(item.SubCategoryName))
                                        {
                                            <span style="margin: 0 4px; opacity:0.5;">/</span>
                                            <span>@item.SubCategoryName</span>
                                        }
                                    </div>

                                    <a href="/Product/ProductDetail/@item.Id" class="bs-title text-capitalize">@item.Name</a>
                                    <div class="bs-price">@item.Price.ToString("C2")</div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="row mt-20">
            <div class="col-12 text-center">
                <a class="more-view-btn d-inline-block border-light-gray2 white-bg theme-color text-capitalize" href="/Product/ProductList">View All Products</a>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    const BSToast = Swal.mixin({
        toast: true,
        position: 'top-end',
        showConfirmButton: false,
        timer: 3000,
        timerProgressBar: true,
        didOpen: (toast) => {
            toast.addEventListener('mouseenter', Swal.stopTimer)
            toast.addEventListener('mouseleave', Swal.resumeTimer)
        }
    });

    async function handleFavoriteBS(productId, btnElement) {
        const icon = btnElement.querySelector('i');
        const token = '@tokens.RequestToken';

        try {
            const response = await fetch('/Favorite/ToggleFavorite', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token,
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: `productId=${productId}`
            });

            if (response.status === 401) {
                 BSToast.fire({
                    icon: 'warning',
                    title: 'Please sign in to add favorites!'
                });
                return;
            }

            const data = await response.json();

            if (response.ok && data.succeeded) {
                icon.className = data.isFavorite ? 'fas fa-heart' : 'far fa-heart';

                BSToast.fire({
                    icon: data.isFavorite ? 'success' : 'info',
                    title: data.message
                });
            } else {
                BSToast.fire({
                    icon: 'warning',
                    title: data.message || 'Action failed.'
                });
            }
        } catch (error) {
            BSToast.fire({
                icon: 'error',
                title: 'A technical error occurred!'
            });
        }
    }
</script>
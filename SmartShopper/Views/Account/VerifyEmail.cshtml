@using Core_Layer.Dtos.AuthDtos
@model ConfirmUserEmailDto

@{
    ViewData["Title"] = "Verify Email";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            @if (TempData["SuccessRegisterMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    @TempData["SuccessRegisterMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div id="ajaxAlertArea"></div>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-primary py-3 border-0">
                    <h5 class="text-white text-center mb-0 tracking-wider">SECURE VERIFICATION</h5>
                </div>
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 70px; height: 70px;">
                            <i class="bi bi-envelope-open-fill fs-2"></i>
                        </div>
                        <h3 class="fw-bold">Check Your Inbox</h3>
                        <p class="text-muted">
                            We've sent a 6-digit code to:<br />
                            <span class="text-primary fw-semibold">@ViewBag.Email</span>
                        </p>
                    </div>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger border-0 shadow-sm mb-4">
                            <div asp-validation-summary="All" class="small"></div>
                        </div>
                    }

                    <form asp-action="VerifyEmail" method="post">
                        <input type="hidden" asp-for="Email" value="@ViewBag.Email" />

                        <div class="mb-4">
                            <label asp-for="ActivationCode" class="form-label small fw-bold text-muted text-uppercase">Verification Code</label>
                            <input asp-for="ActivationCode"
                                   type="text"
                                   class="form-control form-control-lg text-center fw-bold verification-input"
                                   placeholder="000000"
                                   maxlength="6"
                                   required
                                   autocomplete="off" />
                            <span asp-validation-for="ActivationCode" class="text-danger small"></span>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg rounded-3 py-3 shadow-sm">
                                <i class="bi bi-shield-check me-2"></i>Verify Account
                            </button>
                        </div>
                    </form>

                    <div class="text-center mt-4 pt-3 border-top">
                        <p class="small text-muted mb-0">
                            Didn't receive the code?
                            <a href="javascript:void(0)" id="btnResendCode" class="text-primary fw-bold text-decoration-none">
                                Resend Code
                            </a>
                        </p>
                    </div>
                </div>
            </div>

            <div class="text-center mt-4">
                <a asp-action="Register" class="text-muted small text-decoration-none hover-primary">
                    <i class="bi bi-arrow-left me-1"></i>Back to Registration
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        $(document).ready(function () {
            $("#btnResendCode").click(function (e) {
                e.preventDefault();

                var userEmail = "@ViewBag.Email";
                var $btn = $(this);
                var $alertArea = $("#ajaxAlertArea");

                $btn.addClass("text-muted").css("pointer-events", "none").text("Sending...");

                $.ajax({
                    url: '/Account/ResendCodeAjax',
                    type: 'GET',
                    data: { email: userEmail },
                    success: function (response) {
                        if (response.success) {
                            $alertArea.html(`
                                <div class="alert alert-info border-0 shadow-sm mb-4 animate__animated animate__fadeIn">
                                    <i class="bi bi-info-circle-fill me-2"></i>${response.message}
                                </div>
                            `);
                            setTimeout(function() {
                                $btn.removeClass("text-muted").css("pointer-events", "auto").text("Resend Code");
                            }, 60000);
                        } else {
                            $alertArea.html(`
                                <div class="alert alert-warning border-0 shadow-sm mb-4">
                                    <i class="bi bi-exclamation-triangle-fill me-2"></i>${response.message}
                                </div>
                            `);
                            $btn.removeClass("text-muted").css("pointer-events", "auto").text("Resend Code");
                        }
                    },
                    error: function () {
                        $alertArea.html(`
                            <div class="alert alert-danger border-0 shadow-sm mb-4">
                                <i class="bi bi-x-circle-fill me-2"></i>Something went wrong. Please try again.
                            </div>
                        `);
                        $btn.removeClass("text-muted").css("pointer-events", "auto").text("Resend Code");
                    }
                });
            });
        });
    </script>

    <style>
        .verification-input {
            letter-spacing: 0.8rem;
            font-size: 1.8rem;
            height: 65px;
            border: 2px solid #e9ecef;
            transition: all 0.3s ease;
        }

            .verification-input:focus {
                border-color: #0d6efd;
                box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.1);
            }

        .tracking-wider {
            letter-spacing: 1.5px;
        }

        .rounded-4 {
            border-radius: 1rem !important;
        }

        .hover-primary:hover {
            color: #0d6efd !important;
        }
    </style>
}


@{
    ViewData["Title"] = "Order Successful";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="slider-area over-hidden">
    <div class="single-page page-height3 d-flex align-items-center">
        <div class="container">
            <div class="row">
                <div class="col-12 text-center">
                    <div class="success-wrapper pt-100 pb-100">

                        <canvas id="confetti-canvas" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none;"></canvas>

                        <div class="success-icon mb-40">
                            <div class="check-container d-inline-block">
                                <i class="fa fa-check-circle text-success" style="font-size: 100px; animation: scaleUp 0.5s ease-out;"></i>
                            </div>
                        </div>

                        <h2 class="theme-color mb-20 font-weight-bold">Your order has been successfully received!</h2>

                        <div class="row justify-content-center">
                            <div class="col-xl-6 col-lg-8">
                                <p class="mb-40 text-muted lead">
                                    Great choice! We've received your order and our team has started preparations immediately. You can access your order details and status tracking from your profile.
                                </p>
                            </div>
                        </div>

                        <div class="order-actions mt-20">
                            <a asp-controller="Home" asp-action="Index" class="sub-btn text-white theme-bg border-0 px-5 py-3 shadow-sm mr-3">
                                <i class="fa fa-shopping-cart mr-2"></i> Continue Shopping
                            </a>
                            <a asp-controller="Profile" asp-action="ViewProfile" class="sub-btn border-gray bg-white text-dark px-5 py-3 shadow-sm">
                                <i class="fa fa-user mr-2"></i> See My Orders
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @@keyframes scaleUp {
        0% {
            transform: scale(0);
            opacity: 0;
        }

        70% {
            transform: scale(1.2);
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    .success-wrapper {
        position: relative;
        z-index: 1;
    }

    .sub-btn:hover {
        transform: translateY(-3px);
        transition: all 0.3s;
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.5.1/dist/confetti.browser.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var duration = 3 * 1000;
            var end = Date.now() + duration;

            (function frame() {
                confetti({
                    particleCount: 3,
                    angle: 60,
                    spread: 55,
                    origin: { x: 0 },
                    colors: ['#ffb400', '#222222', '#ff5e14'] // SmartShopper tema renkleri
                });
                confetti({
                    particleCount: 3,
                    angle: 120,
                    spread: 55,
                    origin: { x: 1 },
                    colors: ['#ffb400', '#222222', '#ff5e14']
                });

                if (Date.now() < end) {
                    requestAnimationFrame(frame);
                }
            }());
        });
    </script>
}
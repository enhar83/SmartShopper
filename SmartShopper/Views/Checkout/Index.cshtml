@using Core_Layer.Dtos.DiscountDtos
@using Entity_Layer
@model Core_Layer.Dtos.OrderDtos.CheckoutSummaryDto
@{
    ViewData["Title"] = "Checkout";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var addresses = ViewBag.Addresses as List<Core_Layer.Dtos.UserAddressDtos.UserAddressListForCheckoutDto>;
    var coupons = ViewBag.Coupons as List<UserDiscountListDto>;
}

<div class="slider-area over-hidden">
    <div class="single-page page-height3 d-flex align-items-center">
        <div class="container">
            <div class="row">
                <div class="col-12 d-flex align-items-center justify-content-center">
                    <div class="page-title pt-60 pb-70 text-center">
                        <h2 class="text-capitalize theme-color mb-20">Checkout</h2>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb justify-content-center bg-transparent">
                                <li class="breadcrumb-item"><a class="primary-color" asp-controller="Home" asp-action="Index">Home</a></li>
                                <li class="breadcrumb-item active text-capitalize">Checkout</li>
                            </ol>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="checkout-area pb-60">
    <div class="container-wrapper extra-padding-15">

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger mb-30">@TempData["ErrorMessage"]</div>
        }

        <form asp-controller="Checkout" asp-action="PlaceOrder" method="post" id="checkoutForm">

            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger mb-30" })

            <div class="row">
                <div class="col-xl-6 col-lg-6 col-md-12 col-sm-12 col-12">
                    <div class="checkbox-form">
                        <h4 class="pb-10 mb-20 border-b-light-gray">Delivery Address</h4>

                        @if (addresses != null && addresses.Any())
                        {
                            <div class="row">
                                @foreach (var addr in addresses)
                                {
                                    <div class="col-12 mb-20">
                                        <div class="card border-gray p-3" style="cursor:pointer;">
                                            <div class="custom-control custom-radio">
                                                <input type="radio" id="addr-@addr.Id" name="AddressId" value="@addr.Id" class="custom-control-input">
                                                <label class="custom-control-label w-100" for="addr-@addr.Id">
                                                    <span class="d-block font-weight-bold primary-color">@addr.Title</span>
                                                    <small class="text-muted">@addr.FullAddress</small>
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>

                            @Html.ValidationMessage("AddressId", "", new { @class = "text-danger small d-block mb-3" })

                            <div class="mt-10 mb-30">
                                <a href="/Profile/ViewProfile" class="btn btn-outline-secondary btn-sm d-flex align-items-center justify-content-center py-2">
                                    <i class="fa fa-plus-circle mr-2"></i> Add or Manage Addresses
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning p-4 text-center">
                                <i class="fa fa-exclamation-triangle mb-2 d-block h4"></i>
                                <p class="mb-3">No registered address found in your account.</p>
                                <a href="/Profile/ViewProfile" class="btn theme-bg text-white px-4">
                                    Add New Address
                                </a>
                            </div>
                        }

                        <div class="payment-details mt-40">
                            <h4 class="pb-10 mb-20 border-b-light-gray"><i class="fas fa-credit-card text-primary mr-2"></i> Payment Details</h4>
                            <div class="row">
                                <div class="col-md-6 mb-20">
                                    <label>First Name <span class="text-danger">*</span></label>
                                    @Html.TextBox("FirstName", null, new { @class = "form-control", placeholder = "Enhar" })
                                    @Html.ValidationMessage("FirstName", "", new { @class = "text-danger small" })
                                </div>
                                <div class="col-md-6 mb-20">
                                    <label>Last Name <span class="text-danger">*</span></label>
                                    @Html.TextBox("LastName", null, new { @class = "form-control", placeholder = "Yorulmaz" })
                                    @Html.ValidationMessage("LastName", "", new { @class = "text-danger small" })
                                </div>
                                <div class="col-12 mb-20">
                                    <label>Card Number <span class="text-danger">*</span></label>
                                    @Html.TextBox("CardNumber", null, new { @class = "form-control", placeholder = "1111111111111111", maxlength = "16" })
                                    @Html.ValidationMessage("CardNumber", "", new { @class = "text-danger small" })
                                </div>
                                <div class="col-md-6 mb-20">
                                    <label>CVV <span class="text-danger">*</span></label>
                                    @Html.TextBox("Cvv", null, new { @class = "form-control", placeholder = "000", maxlength = "3" })
                                    @Html.ValidationMessage("Cvv", "", new { @class = "text-danger small" })
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="col-xl-6 col-lg-6 col-md-12 col-sm-12 col-12">

                    <div class="card radius-10 border shadow-sm mb-4">
                        <div class="card-body p-4">
                            <h4 class="pb-10 mb-20 border-b-light-gray"><i class="fas fa-ticket-alt text-warning mr-2"></i> Apply Coupon</h4>

                            <div class="form-group mb-0">
                                <select name="DiscountId" id="checkoutDiscountSelect" class="form-control rounded-0 border-gray" style="height: 45px;">
                                    <option value="" data-is-valid="empty">-- Select a Coupon --</option>

                                    @if (coupons != null && coupons.Any())
                                    {
                                        var currentCartTotal = Model.TotalPrice;
                                        var now = DateTime.Now;

                                        foreach (var coupon in coupons)
                                        {
                                            bool isMinOrderValid = !coupon.MinOrderAmount.HasValue || currentCartTotal >= coupon.MinOrderAmount.Value;
                                            bool isDateValid = coupon.StartDate <= now && coupon.EndDate >= now;
                                            bool isUsed = coupon.IsUsed;

                                            if (isMinOrderValid && isDateValid && !isUsed)
                                            {
                                                <option value="@coupon.AssignmentId"
                                                        data-is-valid="true"
                                                        data-type="@((int)coupon.Type)"
                                                        data-value="@coupon.Value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)">
                                                    @coupon.CampaignName (@(((int)coupon.Type == 1) ? $"%{coupon.Value:0} OFF" : $"{coupon.Value:C2} OFF"))
                                                </option>
                                            }
                                            else
                                            {
                                                string disableReason = "";
                                                if (isUsed) disableReason = "Already Used";
                                                else if (coupon.EndDate < now) disableReason = "Expired";
                                                else if (coupon.StartDate > now) disableReason = $"Starts on {coupon.StartDate:dd MMM}";
                                                else if (!isMinOrderValid) disableReason = $"Min Cart Total Required: {coupon.MinOrderAmount?.ToString("C2")}";

                                                <option value=""
                                                        data-is-valid="false"
                                                        data-error="@disableReason"
                                                        class="text-danger font-weight-bold">
                                                    @coupon.CampaignName - (@disableReason)
                                                </option>
                                            }
                                        }
                                    }
                                </select>
                            </div>

                            <div id="couponSummaryArea" class="mt-3 d-none">
                                <div id="couponSuccessAlert" class="alert alert-success rounded-0 small py-2 mb-0 d-none justify-content-between align-items-center">
                                    <span><i class="fas fa-check-circle mr-1"></i> Coupon applied successfully!</span>
                                    <span class="font-weight-bold">Saved: <span id="savedAmountText">0 TL</span></span>
                                </div>

                                <div id="couponErrorAlert" class="alert alert-danger rounded-0 small py-2 mb-0 d-none justify-content-between align-items-center">
                                    <span><i class="fas fa-times-circle mr-1"></i> <strong id="couponErrorText">Coupon cannot be applied.</strong></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="your-order mb-30 pt-30 pr-40 pb-45 pl-40 border">
                        <h4 class="pb-10 mb-20 border-b-light-gray">Your Order</h4>
                        <div class="your-order-table table-responsive">
                            <table class="width100">
                                <thead>
                                    <tr>
                                        <th class="product-name text-left">Product</th>
                                        <th class="product-total text-right">Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Items)
                                    {
                                        <tr class="cart_item border-b-light-gray">
                                            <td class="product-name py-3">
                                                @item.ProductName <strong class="product-quantity"> × @item.Quantity</strong>
                                            </td>
                                            <td class="product-total text-right">
                                                <span class="amount">@item.Price.ToString("C")</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr class="cart-subtotal border-b-light-gray">
                                        <th class="py-3">Cart Subtotal</th>
                                        <td class="text-right"><strong>@Model.SubTotal.ToString("C")</strong></td>
                                    </tr>
                                    <tr class="order-total">
                                        <th class="py-3">Order Total</th>
                                        <td class="text-right">
                                            <strong>
                                                <span class="amount text-danger h4"
                                                      id="grandTotalText"
                                                      data-raw-total="@Model.TotalPrice.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                                                    @Model.TotalPrice.ToString("C")
                                                </span>
                                            </strong>
                                        </td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>

                        <div class="payment-method mt-40">
                            <p class="mb-20 text-muted small">
                                * This is a secure payment simulation. Your credit card information is processed securely.
                            </p>
                            <div class="order-button-payment mt-20">
                                <button type="submit" class="sub-btn d-inline-block text-white theme-bg border-0 width100 py-3 font-weight-bold">
                                    COMPLETE PAYMENT & PLACE ORDER
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            const rawTotalStr = $("#grandTotalText").attr("data-raw-total");
            const originalTotal = parseFloat(rawTotalStr) || 0;

            function formatCurrency(amount) {
                return new Intl.NumberFormat('tr-TR', { style: 'currency', currency: 'TRY' }).format(amount);
            }

            $("#checkoutDiscountSelect").on("change", function () {
                const selectedOption = $(this).find('option:selected');
                const isValid = selectedOption.attr("data-is-valid");

                $("#couponSummaryArea").removeClass("d-none");
                $("#couponSuccessAlert").addClass("d-none").removeClass("d-flex");
                $("#couponErrorAlert").addClass("d-none").removeClass("d-flex");

                if (isValid === "empty") {
                    $("#couponSummaryArea").addClass("d-none");
                    $("#grandTotalText").text(formatCurrency(originalTotal));
                    return;
                }

                if (isValid === "false") {
                    const errorMsg = selectedOption.attr("data-error");
                    $("#couponErrorAlert").removeClass("d-none").addClass("d-flex");
                    $("#couponErrorText").text("Not Applicable: " + errorMsg);
                    $("#grandTotalText").text(formatCurrency(originalTotal));

                    $("#couponSummaryArea").fadeOut(100).fadeIn(100).fadeOut(100).fadeIn(100);
                    return;
                }

                const discountType = parseInt(selectedOption.attr("data-type")) || 0;
                const discountValue = parseFloat(selectedOption.attr("data-value")) || 0;

                let savedAmount = 0;
                let newTotal = originalTotal;

                if (discountType === 1) {
                    savedAmount = (originalTotal * discountValue) / 100;
                    newTotal = originalTotal - savedAmount;
                } else if (discountType === 2) {
                    savedAmount = discountValue;
                    newTotal = originalTotal - savedAmount;
                    if (newTotal < 0) newTotal = 0;
                }

                if (savedAmount > 0) {
                    $("#couponSuccessAlert").removeClass("d-none").addClass("d-flex");
                    $("#savedAmountText").text(formatCurrency(savedAmount));
                    $("#grandTotalText").text(formatCurrency(newTotal));

                    $("#grandTotalText").fadeOut(150).fadeIn(150).css("color", "#28a745", "important");
                    setTimeout(() => $("#grandTotalText").css("color", ""), 1000);
                }
            });
        });
    </script>
}
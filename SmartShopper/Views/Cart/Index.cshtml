@using Core_Layer.Dtos.CartDtos
@model CartDto

@{
    ViewData["Title"] = "Shopping Cart";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var tokens = Antiforgery.GetAndStoreTokens(Context);
}

<div class="slider-area over-hidden">
    <div class="single-page page-height3 d-flex align-items-center">
        <div class="container">
            <div class="row">
                <div class="col-xl-12 col-lg-12 col-md-12 col-sm-12 col-12 d-flex align-items-center justify-content-center">
                    <div class="page-title pt-60 pb-70 text-center">
                        <h2 class="text-capitalize theme-color mb-20">Shopping Cart</h2>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb justify-content-center bg-transparent">
                                <li class="breadcrumb-item"><a class="primary-color" href="/">Home</a></li>
                                <li class="breadcrumb-item active text-capitalize" aria-current="page">Cart</li>
                            </ol>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="cart-area">
    <div class="container-wrapper extra-padding-15 border-b-light-gray pb-100">
        <div id="cart-content-wrapper">
            <div class="text-center pt-50 pb-50">
                <div class="spinner-border theme-color" role="status">
                    <span class="sr-only">Loading...</span>
                </div>
                <p class="mt-15">Fetching your shopping items...</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            cartModule.init();
        });

        const cartModule = (function () {
            const requestToken = '@tokens.RequestToken';

            const init = function () {
                fetchCartData();
            };

            const fetchCartData = function () {
                $.ajax({
                    url: '/Cart/GetCartData',
                    type: 'GET',
                    success: function (response) {
                        renderUI(response);
                    },
                    error: function (err) {
                        console.error("Cart fetch error:", err);
                        $("#cart-content-wrapper").html('<div class="alert alert-danger text-center">Failed to load cart.</div>');
                    }
                });
            };

            const renderUI = function (data) {
                const wrapper = $("#cart-content-wrapper");

                if (!data || !data.items || data.items.length === 0) {
                    wrapper.html(`
                        <div class="empty-cart-message text-center pt-80 pb-80">
                            <div class="icon mb-30">
                                <i class="fas fa-shopping-basket" style="font-size: 100px; color: #e2e2e2;"></i>
                            </div>
                            <h3 class="theme-color">Your shopping cart is empty.</h3>
                            <p class="text-muted">Explore our latest products to fill your cart!</p>
                            <a href="/Product/ProductList" class="sub-btn d-inline-block theme-bg text-white mt-30 shadow-sm" style="padding: 12px 30px; border-radius: 5px; text-decoration: none;">RETURN TO SHOP</a>
                        </div>
                    `);
                    return;
                }

                    let itemsRows = '';
        data.items.forEach(item => {
            const hasImage = item.productImageUrl &&
                             item.productImageUrl !== 'NO_IMAGE' &&
                             item.productImageUrl !== '/img/no-image.png';

            const imageHtml = hasImage
                ? `<img src="${item.productImageUrl}" alt="${item.productName}" style="width:80px; height:100px; object-fit:cover; border-radius: 5px;">`
                : `<div style="width:80px; height:100px; background:#f5f5f5; display:flex; align-items:center; justify-content:center; border-radius:5px; color:#ccc; flex-direction:column;">
                    <i class="fas fa-image fa-2x"></i>
                    <span style="font-size:10px; margin-top:5px;">No Image</span>
                   </div>`;

            itemsRows += `
                <tr>
                    <td>
                        <a href="/Product/ProductDetails/${item.productId}" class="cart-img d-block">
                            ${imageHtml}
                        </a>
                    </td>
                    <td class="text-left">
                        <a href="/Product/ProductDetails/${item.productId}" class="p-name theme-color font-weight-bold">
                            ${item.productName}
                        </a>
                    </td>
                    <td>$${item.price.toFixed(2)}</td>
                    <td>
                        <div class="quantity-control d-flex align-items-center justify-content-center">
                            <button class="btn btn-sm btn-outline-secondary" onclick="cartModule.updateQuantity('${item.id}', ${item.quantity - 1})">-</button>
                            <input type="text" value="${item.quantity}" class="form-control text-center mx-2" style="width: 50px; font-weight: bold;" readonly>
                            <button class="btn btn-sm btn-outline-secondary" onclick="cartModule.updateQuantity('${item.id}', ${item.quantity + 1})">+</button>
                        </div>
                    </td>
                    <td><span class="font-weight-bold theme-color">$${(item.price * item.quantity).toFixed(2)}</span></td>
                    <td>
                        <button onclick="cartModule.removeItem('${item.id}')" class="btn btn-link text-danger p-0" title="Remove Item">
                            <i class="fas fa-trash-alt" style="font-size: 18px;"></i>
                        </button>
                    </td>
                </tr>
            `;
        });

                wrapper.html(`
                    <div class="cart-table table-responsive">
                        <table class="table text-center border shadow-sm">
                            <thead class="bg-light">
                                <tr>
                                    <th>Image</th>
                                    <th>Product</th>
                                    <th>Price</th>
                                    <th>Quantity</th>
                                    <th>Subtotal</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>${itemsRows}</tbody>
                        </table>
                    </div>
                    <div class="coupon-and-update-area pt-20">
                        <div class="row align-items-center">
                            <div class="col-xl-6 col-lg-6 col-md-6 col-sm-12 col-12">
                                <div class="update-area">
                                     <button onclick="cartModule.clearCart()" class="sub-btn d-inline-block bg-danger text-white border-0 px-4 py-2 rounded shadow-sm">CLEAR CART</button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row mt-30 justify-content-end">
                        <div class="col-xl-4 col-lg-5 col-md-7 col-12">
                            <div class="total-price-area p-4 border rounded bg-light shadow-sm">
                                <h4 class="mb-3 theme-color border-bottom pb-2">Cart Totals</h4>
                                <div class="d-flex justify-content-between mb-3">
                                    <span class="font-weight-bold">Grand Total</span>
                                    <span class="h4 theme-color font-weight-bold">$${data.grandTotal.toFixed(2)}</span>
                                </div>
                                <a href="/Checkout/Index" class="btn btn-block theme-bg text-white py-3 font-weight-bold rounded shadow-sm" style="text-decoration: none;">PROCEED TO CHECKOUT</a>
                            </div>
                        </div>
                    </div>
                `);
            };

            const updateQuantity = function (id, newQty) {
                if (newQty < 1) {
                    cartModule.removeItem(id);
                    return;
                }

                $.ajax({
                    url: '/Cart/UpdateCartItem',
                    type: 'POST',
                    contentType: 'application/json',
                    headers: { "RequestVerificationToken": requestToken },
                    data: JSON.stringify({ Id: id, Quantity: newQty }),
                    success: function (res) {
                        if (res.success) {
                            fetchCartData(); 
                            if (typeof refreshMiniCart === "function") refreshMiniCart(); 
                        } else {
                            Swal.fire({ icon: 'warning', title: 'Stock Warning', text: res.message });
                        }
                    },
                    error: function () {
                        Swal.fire({ icon: 'error', title: 'Error', text: 'An error occurred while updating quantity.' });
                    }
                });
            };

            const removeItem = function (id) {
                Swal.fire({
                    title: 'Remove Item?',
                    text: "Are you sure you want to remove this product from your cart?",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#e67e22',
                    cancelButtonColor: '#d33',
                    confirmButtonText: 'Yes, remove it!',
                    cancelButtonText: 'Cancel'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: `/Cart/RemoveCartItem?id=${id}`,
                            type: 'POST',
                            headers: { "RequestVerificationToken": requestToken },
                            success: function (res) {
                                if (res.success) {
                                    fetchCartData(); 
                                    if (typeof refreshMiniCart === "function") refreshMiniCart(); 

                                    const Toast = Swal.mixin({
                                        toast: true,
                                        position: 'top-end',
                                        showConfirmButton: false,
                                        timer: 2000,
                                        timerProgressBar: true
                                    });
                                    Toast.fire({ icon: 'success', title: res.message });
                                } else {
                                    Swal.fire({ icon: 'error', title: 'Error', text: res.message });
                                }
                            },
                            error: function () {
                                Swal.fire({ icon: 'error', title: 'Error', text: 'An error occurred while removing the item.' });
                            }
                        });
                    }
                });
            };

            const clearCart = function () {
                Swal.fire({
                    title: 'Clear All Cart?',
                    text: "This will remove all items from your shopping cart. This action cannot be undone!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Yes, clear all!',
                    cancelButtonText: 'No, keep items'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '/Cart/ClearCart',
                            type: 'POST',
                            headers: { "RequestVerificationToken": requestToken },
                            success: function (res) {
                                if (res.success) {
                                    fetchCartData(); 
                                    if (typeof refreshMiniCart === "function") refreshMiniCart(); 

                                    Swal.fire({ icon: 'success', title: 'Cleared!', text: res.message, timer: 2000, showConfirmButton: false });
                                } else {
                                    Swal.fire({ icon: 'error', title: 'Error', text: res.message });
                                }
                            },
                            error: function () {
                                Swal.fire({ icon: 'error', title: 'Error', text: 'An error occurred while clearing the cart.' });
                            }
                        });
                    }
                });
            };

            return {
                init: init,
                updateQuantity: updateQuantity,
                removeItem: removeItem,
                clearCart: clearCart
            };

        })();
    </script>
}